{
  "name": "eventsgateway-www-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "EventsGateway public site and www worker.",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "npm run check:www",
    "check:www": "astro check",
    "check:dashboard": "npm --prefix apps/dashboard run check",
    "check:api": "npm --prefix apps/api-worker run check",
    "check:collector": "npm --prefix apps/collector-worker run check",
    "check:forwarder": "npm --prefix apps/forwarder-worker run check",
    "build": "npm run build:www",
    "build:www": "node scripts/build-www-worker.mjs",
    "build:dashboard": "npm --prefix apps/dashboard run build",
    "build:api": "npm --prefix apps/api-worker run build",
    "build:collector": "npm --prefix apps/collector-worker run build",
    "build:forwarder": "npm --prefix apps/forwarder-worker run build",
    "postinstall": "node scripts/install-wrangler-wrapper.mjs",
    "postbuild": "node scripts/minify-html.mjs",
    "preview": "astro preview",
    "deploy": "npm run deploy:www",
    "deploy:www": "npm run build:www && wrangler deploy --env production",
    "deploy:public": "npm run deploy:www",
    "deploy:hosted": "npm run deploy:www",
    "deploy:dashboard": "npm --prefix apps/dashboard run deploy",
    "deploy:api": "npm --prefix apps/api-worker run deploy",
    "deploy:collector": "npm --prefix apps/collector-worker run deploy",
    "deploy:forwarder": "npm --prefix apps/forwarder-worker run deploy",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.6.0",
    "astro": "^6.3.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "html-minifier-terser": "^7.2.0",
    "typescript": "^5.9.2",
    "wrangler": "^4.20.3"
  }
}
