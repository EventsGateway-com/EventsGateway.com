{
  "name": "ai-dev-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Premium Astro marketing site for AI development workflows.",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "build": "node scripts/build-unified-app.mjs",
    "postinstall": "node scripts/install-wrangler-wrapper.mjs",
    "postbuild": "node scripts/minify-html.mjs",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler deploy --env production",
    "deploy:public": "npm run deploy",
    "deploy:hosted": "npm run deploy",
    "deploy:all": "npm run deploy",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.6.0",
    "astro": "^6.3.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "html-minifier-terser": "^7.2.0",
    "typescript": "^5.9.2",
    "wrangler": "^4.20.3"
  }
}
