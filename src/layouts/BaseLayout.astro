---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { siteConfig } from "../config/site";

const {
  title,
  description = siteConfig.description,
  canonicalPath = "/",
  ogImage = siteConfig.ogImage,
  jsonLd
} = Astro.props as {
  title: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
};

const canonicalUrl = new URL(canonicalPath, siteConfig.domain).toString();
const ogImageUrl = new URL(ogImage, siteConfig.domain).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/x-icon" href="/eventsgateway-icon-card.ico" />
    <link rel="icon" type="image/svg+xml" href="/eventsgateway-icon-symbol-only.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>}
    <script is:inline>
      (function() {
        try {
          const theme = localStorage.getItem('eg_theme') || 'system';
          if (theme === 'light' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: light)').matches)) {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <div class="site-shell">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
    <div class="cookie-bar" data-cookie-bar hidden>
      <div class="cookie-bar__copy">
        <strong>Cookies and tracking</strong>
        <p>EVENTS Gateway uses essential storage for site behavior and optional analytics cookies for product measurement.</p>
      </div>
      <div class="cookie-bar__actions">
        <button class="cookie-bar__button cookie-bar__button--ghost" type="button" data-cookie-action="essential">Essential only</button>
        <button class="cookie-bar__button" type="button" data-cookie-action="accept">Accept all</button>
      </div>
    </div>
    <script is:inline src="/scripts/floating-labels.js" defer></script>
    <script is:inline src="/scripts/cookie-consent.js" defer></script>
    <script is:inline>
      (() => {
        async function initPublicSiteTracking() {
          try {
            await new Promise((resolve, reject) => {
              if (window.eventsgateway) {
                resolve(window.eventsgateway);
                return;
              }

              const existing = document.querySelector('script[data-site-tracker-loader="true"]');
              if (existing) {
                existing.addEventListener("load", () => resolve(window.eventsgateway), { once: true });
                existing.addEventListener("error", reject, { once: true });
                return;
              }

              const script = document.createElement("script");
              script.src = "/e/";
              script.defer = true;
              script.dataset.siteTrackerLoader = "true";
              script.addEventListener("load", () => resolve(window.eventsgateway), { once: true });
              script.addEventListener("error", reject, { once: true });
              document.head.appendChild(script);
            });

            const response = await fetch("/api/public-site-tracking", {
              headers: {
                accept: "application/json"
              }
            });
            if (!response.ok) {
              return;
            }

            const config = await response.json();
            if (!config?.enabled || !config.site_id || !config.api_key || !window.eventsgateway?.init) {
              return;
            }

            window.eventsgateway.init({
              siteId: config.site_id,
              apiKey: config.api_key,
              endpoint: config.endpoint || "/i/",
              environment: "production",
              autoPageview: false
            });
            window.eventsgateway.pageview({
              page_group: "marketing-site"
            });
          } catch {}
        }

        void initPublicSiteTracking();
      })();
    </script>
    <script is:inline src="/scripts/card-drag.js" defer></script>
  </body>
</html>

<style>
  .cookie-bar {
    position: fixed;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    z-index: 80;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.1rem;
    border: 1px solid rgba(125, 211, 252, 0.16);
    border-radius: 1rem;
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.08), rgba(255, 255, 255, 0.02)),
      rgba(7, 11, 20, 0.95);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(20px);
  }

  .cookie-bar__copy {
    display: grid;
    gap: 0.35rem;
  }

  .cookie-bar__copy strong {
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: -0.02em;
  }

  .cookie-bar__copy p {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.55;
  }

  .cookie-bar__actions {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .cookie-bar__button {
    min-height: 2.7rem;
    padding: 0.7rem 1rem;
    border: 1px solid rgba(125, 211, 252, 0.22);
    border-radius: 0.9rem;
    background: rgba(125, 211, 252, 0.12);
    color: var(--color-text);
    cursor: pointer;
  }

  .cookie-bar__button--ghost {
    background: rgba(255, 255, 255, 0.03);
    color: var(--color-muted);
  }

  @media (max-width: 720px) {
    .cookie-bar {
      flex-direction: column;
      align-items: stretch;
    }

    .cookie-bar__actions {
      width: 100%;
    }

    .cookie-bar__button {
      flex: 1 1 0;
    }
  }
</style>
