---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Container from "../components/Container.astro";
import { siteConfig } from "../config/site";
---

<BaseLayout
  title={`Page not found — ${siteConfig.name}`}
  description="The requested page does not exist."
  canonicalPath="/404/"
>
  <section class="section section--hero">
    <Container>
      <div class="surface-panel cta-panel not-found">
        <div class="surface-panel__inner stack">
          <span class="eyebrow">404</span>
          <h1 class="page-title">This route is not part of the public EVENTS Gateway site.</h1>
          <p class="page-copy">
            The page you tried to reach is unavailable, moved, or not published in this static release.
          </p>
          <div class="button-row">
            <Button href="/" variant="primary" icon="arrow-right">Home</Button>
            <Button href="/download/" variant="secondary" icon="download">Download</Button>
            <Button href="/contact/" variant="secondary" icon="mail">Contact</Button>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .not-found {
    max-width: 52rem;
    margin: 0 auto;
  }
</style>
