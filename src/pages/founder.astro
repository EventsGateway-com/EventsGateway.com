---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Container from "../components/Container.astro";
import PremiumCard from "../components/PremiumCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
---

<BaseLayout
  title="Founder"
  description="Founder profile for Marian Vasile, founder of EVENTS Gateway."
  canonicalPath="/founder/"
>
  <section class="section page-hero">
    <Container>
      <div class="stack">
        <span class="eyebrow">Founder</span>
        <h1 class="page-title">Marian Vasile</h1>
        <p class="page-copy">
          Marian Vasile is the founder of <strong>EVENTS Gateway</strong> and a SaaS product builder with more than 20 years of experience across aviation, ecommerce, and AI-driven software.
        </p>
        <div class="button-row">
          <Button href="https://marianvasile.com/en" variant="primary" icon="arrow-right">Visit profile</Button>
          <Button href="/contact/" variant="secondary" icon="mail">Contact form</Button>
        </div>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Profile"
        title="Product, growth, and technical leadership."
        description="The public profile combines SaaS architecture, product strategy, search growth, paid media execution, and hands-on delivery."
      />
      <div class="card-grid">
        <PremiumCard icon="spark" title="SaaS builder" text="Builds SaaS products and digital systems with a focus on practical architecture and clear operations." />
        <PremiumCard icon="layers" title="20+ years experience" text="Long-term experience across digital strategy, product delivery, and technical execution." />
        <PremiumCard icon="check" title="13+ startups mentored" text="Supports startup teams with product thinking, growth systems, and execution structure." />
        <PremiumCard icon="terminal" title="100K+ websites using his tech" text="Technology shaped by real distribution and production use across a large number of websites." />
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <div class="card-grid">
        <PremiumCard title="Based in Bucharest, Romania" text="The public founder profile lists Bucharest as the operating base for contact and collaboration." />
        <PremiumCard title="Direct contact" text="Use the public profile or the site contact page for founder outreach." />
      </div>
    </Container>
  </section>
</BaseLayout>
