---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button.astro";
import Container from "../../components/Container.astro";
import PremiumCard from "../../components/PremiumCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { compareMeta } from "../../content/compare-meta";
import { comparePages, type CompareSlug } from "../../content/compare-pages";

export function getStaticPaths() {
  return Object.keys(comparePages).map((slug) => ({
    params: { slug },
    props: { page: comparePages[slug as CompareSlug] }
  }));
}

const { page } = Astro.props as {
  page: (typeof comparePages)[CompareSlug];
};

const meta = compareMeta[Astro.params.slug as CompareSlug];

const renderScore = (value: number) => "●".repeat(value) + "○".repeat(5 - value);
---

<BaseLayout
  title={page.title}
  description={page.description}
  canonicalPath={`/compare/${Astro.params.slug}/`}
>
  <section class="section page-hero">
    <Container>
      <div class="stack">
        <span class="eyebrow">Comparison</span>
        <h1 class="page-title">{page.title}</h1>
        <p class="page-copy">{page.description}</p>
        <div class="pill-row">
          <span class="status-pill">{meta.category}</span>
          <span class="status-pill">{meta.bestFor}</span>
        </div>
        <div class="button-row">
          <Button href="/compare/" variant="secondary" icon="arrow-right">Back to comparisons</Button>
          <Button href="/install/" variant="primary" icon="download">Install EventsGateway</Button>
          <Button href="/why-not-direct-pixels/" variant="secondary" icon="arrow-right">Why not direct pixels?</Button>
        </div>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Scorecard"
        title="A fast read on where each option wins."
        description="This scorecard helps you see which option gives marketers cleaner data, better matching inputs, and a simpler path to better campaign performance."
      />
      <div class="card-grid">
        {
          meta.scorecard.map((item) => (
            <PremiumCard icon="layers" title={item.label} text={item.note} eyebrow="Scorecard">
              <div class="score-rail">
                <div class="score-rail__row">
                  <span>Alternative</span>
                  <code>{renderScore(item.alternative)}</code>
                </div>
                <div class="score-rail__row">
                  <span>EventsGateway</span>
                  <code>{renderScore(item.eventsgateway)}</code>
                </div>
              </div>
            </PremiumCard>
          ))
        }
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Quick Verdict"
        title={page.winner}
        description="This page is designed to make the marketer trade-off obvious in plain language."
      />
      <div class="card-grid">
        {
          page.points.map((item) => (
            <PremiumCard icon="check" title={item.title} text={item.text} />
          ))
        }
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <SectionHeader
        eyebrow="Head-to-Head"
        title="Side-by-side comparison."
        description="The goal here is clarity for marketers, not generic feature grids."
      />
      <div class="surface-panel table-panel">
        <div class="surface-panel__inner">
          <div class="docs-table-wrap">
            <table class="docs-table">
              <thead>
                <tr>
                  <th>Dimension</th>
                  <th>Alternative</th>
                  <th>EventsGateway</th>
                </tr>
              </thead>
              <tbody>
                {
                  page.table.map((row) => (
                    <tr>
                      <td>{row[0]}</td>
                      <td>{row[1]}</td>
                      <td>{row[2]}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .table-panel {
    overflow: hidden;
  }

  .docs-table-wrap {
    overflow-x: auto;
  }

  .docs-table {
    width: 100%;
    min-width: 760px;
    border-collapse: collapse;
  }

  .docs-table th,
  .docs-table td {
    padding: 0.95rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    text-align: left;
    vertical-align: top;
    line-height: 1.6;
  }

  .docs-table th {
    color: var(--color-subtle);
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .score-rail {
    display: grid;
    gap: 0.8rem;
  }

  .score-rail__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--color-muted);
  }

  .score-rail__row code {
    font-family: var(--font-mono);
    color: var(--color-text);
    letter-spacing: 0.2em;
    white-space: nowrap;
  }
</style>
