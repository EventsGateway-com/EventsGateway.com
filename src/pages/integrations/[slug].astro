---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button.astro";
import Container from "../../components/Container.astro";
import PremiumCard from "../../components/PremiumCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { integrationsContent, type IntegrationSlug } from "../../content/integrations";

export function getStaticPaths() {
  return integrationsContent.items.map((item) => ({
    params: { slug: item.slug },
    props: { item }
  }));
}

const { item } = Astro.props as {
  item: (typeof integrationsContent.items)[number];
};
---

<BaseLayout
  title={`${item.label} - EVENTS Gateway`}
  description={item.summary}
  canonicalPath={`/integrations/${Astro.params.slug as IntegrationSlug}/`}
>
  <section class="section page-hero">
    <Container>
      <div class="stack">
        <span class="eyebrow">Integration</span>
        <img class="integration-hero-logo" src={`/integrations/logos/${item.slug}.svg`} alt={`${item.label} logo`} loading="eager" />
        <h1 class="page-title">{item.title}</h1>
        <p class="page-copy">{item.hero}</p>
        <div class="button-row">
          <Button href="https://dash.eventsgateway.com/register" variant="primary" icon="arrow-right">Start free</Button>
          {(item as any).repository && (
            <Button href={(item as any).repository} variant="secondary" icon="arrow-right">Open source component</Button>
          )}
          <Button href="/integrations/" variant="secondary" icon="arrow-right">Back to integrations</Button>
        </div>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Why It Matters"
        title={`Why teams connect ${item.label} through EVENTS Gateway`}
        description="The value is practical: cleaner data, fewer mismatched numbers, and better optimization inputs without rebuilding tracking from scratch."
      />
      <div class="card-grid">
        {item.points.map((point) => <PremiumCard imageSrc={`/integrations/logos/${item.slug}.svg`} imageAlt={`${item.label} logo`} title={item.label} text={point} />)}
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Use Cases"
        title="Where this integration creates the biggest lift"
        description="These are the situations where one shared event model usually saves the most time and prevents the most reporting drift."
      />
      <div class="card-grid">
        {item.useCases.map((point) => <PremiumCard imageSrc={`/integrations/logos/${item.slug}.svg`} imageAlt={`${item.label} logo`} title={item.label} text={point} />)}
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <div class="surface-panel cta-panel">
        <div class="surface-panel__inner stack">
          <span class="eyebrow">Next Step</span>
          <h2 class="section-title">Connect this destination without multiplying tracking complexity.</h2>
          <p class="section-copy">
            EVENTS Gateway lets your team keep one cleaner event setup while sending the same lead, purchase, and
            lifecycle truth to the platforms that matter most.
          </p>
          <div class="button-row">
            <Button href="/pricing/" variant="primary" icon="arrow-right">Open pricing</Button>
            <Button href="/contact/" variant="secondary" icon="mail">Talk to us</Button>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .integration-hero-logo {
    width: 4.75rem;
    height: 4.75rem;
    border-radius: 1.15rem;
    display: block;
  }
</style>
