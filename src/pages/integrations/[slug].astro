---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button.astro";
import Container from "../../components/Container.astro";
import PremiumCard from "../../components/PremiumCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { integrationsContent, type IntegrationSlug } from "../../content/integrations";

export function getStaticPaths() {
  return integrationsContent.items.map((item) => ({
    params: { slug: item.slug },
    props: { item }
  }));
}

const { item } = Astro.props as {
  item: (typeof integrationsContent.items)[number];
};

const accentPhrases = [
  "same conversion truth",
  "same trusted event stream",
  "same event system",
  "same event model",
  "one shared event layer",
  "one cleaner event source",
  "one event model",
  "one event layer",
  "cleaner Reserve with Google signals",
  "cleaner conversion actions",
  "cleaner downstream data",
  "cleaner conversion truth",
  "stronger purchase and lead signals",
  "purchase and lead signals",
  "purchase and lead events",
  "lead capture, CRM updates, automations, and revenue events",
  "bookings, reservations, and local leads",
  "business outcomes",
  "signal quality",
  "local discovery",
  "revenue events",
  "pipeline signals",
  "EMQ",
  "Meta EMQ"
];

const escapeHtml = (value: string) =>
  value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");

const emphasizeText = (value: string) => {
  const escaped = escapeHtml(value);

  for (const phrase of accentPhrases) {
    const escapedPhrase = escapeHtml(phrase);
    const lower = escaped.toLowerCase();
    const target = escapedPhrase.toLowerCase();
    const index = lower.indexOf(target);

    if (index !== -1) {
      const before = escaped.slice(0, index);
      const after = escaped.slice(index + escapedPhrase.length);
      const safeBefore = before.endsWith(" ") ? `${before.slice(0, -1)}&nbsp;` : before;
      const safeAfter = after.startsWith(" ") ? `&nbsp;${after.slice(1)}` : after;

      return `${safeBefore}<span class="copy-accent">${escaped.slice(index, index + escapedPhrase.length)}</span>${safeAfter}`;
    }
  }

  return escaped;
};
---

<BaseLayout
  title={`${item.label} - EVENTS Gateway`}
  description={item.summary}
  canonicalPath={`/integrations/${Astro.params.slug as IntegrationSlug}/`}
>
  <section class="section page-hero">
    <Container>
      <div class="stack">
        <span class="eyebrow">Integration</span>
        <img class="integration-hero-logo" src={`/integrations/logos/${item.slug}.svg`} alt={`${item.label} logo`} loading="eager" />
        <h1 class="page-title" set:html={emphasizeText(item.title)} />
        <p class="page-copy page-copy--lead" set:html={emphasizeText(item.summary)} />
        <p class="page-copy" set:html={emphasizeText(item.hero)} />
        <div class="button-row">
          <Button href="https://dash.eventsgateway.com/register" variant="primary" icon="arrow-right">Start free</Button>
          {(item as any).repository && (
            <Button href={(item as any).repository} variant="secondary" icon="arrow-right">Open source component</Button>
          )}
          <Button href="/integrations/" variant="secondary" icon="arrow-right">Back to integrations</Button>
        </div>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Why It Matters"
        title={item.whyTitle}
        titleHtml={emphasizeText(item.whyTitle)}
        description={item.whyDescription}
        descriptionHtml={emphasizeText(item.whyDescription)}
      />
      <div class="card-grid">
        {item.reasons.map((reason) => <PremiumCard imageSrc={`/integrations/logos/${item.slug}.svg`} imageAlt={`${item.label} logo`} title={reason.title} titleHtml={emphasizeText(reason.title)} text={reason.text} textHtml={emphasizeText(reason.text)} />)}
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Use Cases"
        title={item.useCasesTitle}
        titleHtml={emphasizeText(item.useCasesTitle)}
        description={item.useCasesDescription}
        descriptionHtml={emphasizeText(item.useCasesDescription)}
      />
      <div class="card-grid">
        {item.useCases.map((useCase) => <PremiumCard imageSrc={`/integrations/logos/${item.slug}.svg`} imageAlt={`${item.label} logo`} title={useCase.title} titleHtml={emphasizeText(useCase.title)} text={useCase.text} textHtml={emphasizeText(useCase.text)} />)}
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <div class="surface-panel cta-panel">
        <div class="surface-panel__inner stack">
          <span class="eyebrow">Next Step</span>
          <h2 class="section-title" set:html={emphasizeText(item.ctaTitle)} />
          <p class="section-copy" set:html={emphasizeText(item.ctaText)} />
          <div class="button-row">
            <Button href="/pricing/" variant="primary" icon="arrow-right">Open pricing</Button>
            <Button href="/contact/" variant="secondary" icon="mail">Talk to us</Button>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .integration-hero-logo {
    width: 4.75rem;
    height: 4.75rem;
    border-radius: 1.15rem;
    display: block;
  }

  .page-copy--lead {
    color: var(--color-text);
    font-size: 1.1rem;
    max-width: 58rem;
  }

  :global(.copy-accent) {
    color: var(--color-accent);
  }
</style>
