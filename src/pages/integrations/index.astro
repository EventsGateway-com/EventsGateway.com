---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button.astro";
import Container from "../../components/Container.astro";
import PremiumCard from "../../components/PremiumCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { integrationsContent } from "../../content/integrations";
import { emphasizeBrand } from "../../utils/emphasize-brand";
---

<BaseLayout
  title="Integrations - EVENTS Gateway"
  description={integrationsContent.intro}
  canonicalPath="/integrations/"
>
  <section class="section page-hero">
    <Container>
      <div class="stack">
        <span class="eyebrow">{integrationsContent.eyebrow}</span>
        <h1 class="page-title" set:html={emphasizeBrand(integrationsContent.title)} />
        <p class="page-copy" set:html={emphasizeBrand(integrationsContent.intro)} />
        <p class="page-copy">Browse {integrationsContent.items.length} integrations built to improve signal quality, reduce reporting drift, and keep launch work lighter.</p>
        <div class="button-row">
          <Button href="https://dash.eventsgateway.com/register" variant="primary" icon="arrow-right">Start free</Button>
          <Button href="/contact/" variant="secondary" icon="mail">Talk to us</Button>
        </div>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Available Integrations"
        title="Choose the destinations that unlock better data, not more setup."
        description="Every integration is built to help you launch faster, reduce duplicate tagging, and keep every team working from the same conversion truth."
      />
      <div class="card-grid">
        {
          integrationsContent.items.map((item) => (
            <PremiumCard imageSrc={`/integrations/logos/${item.slug}.svg`} imageAlt={`${item.label} logo`} title={item.label} text={item.summary}>
              <Button href={`/integrations/${item.slug}/`} variant="secondary" icon="arrow-right">See use cases</Button>
            </PremiumCard>
          ))
        }
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <div class="surface-panel cta-panel">
        <div class="surface-panel__inner stack">
          <span class="eyebrow">Next Step</span>
          <h2 class="section-title">Stop rebuilding the same tracking logic for every destination.</h2>
          <p class="section-copy">
            <strong>EVENTS Gateway</strong> helps your team collect once, route everywhere, and keep ads, analytics, CRM, and reporting
            closer to the same clean conversion truth.
          </p>
          <div class="button-row">
            <Button href="/pricing/" variant="primary" icon="arrow-right">Open pricing</Button>
            <Button href="/docs/" variant="secondary" icon="arrow-right">Read docs</Button>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
