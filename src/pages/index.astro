---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import CommandCenterMockup from "../components/CommandCenterMockup.astro";
import Container from "../components/Container.astro";
import PremiumCard from "../components/PremiumCard.astro";
import RealtimeHeroStats from "../components/RealtimeHeroStats.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { homeContent } from "../content/homepage";
import { siteConfig } from "../config/site";

const heroTelemetry = homeContent.stats;
const heroOutcomes = [
  "Higher Event Match Score for Meta campaigns",
  "Cleaner conversions for Google Ads and TikTok Ads",
  "More reliable mobile and iOS tracking",
  "Less wasted spend caused by broken or fragmented signals"
];

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: siteConfig.name,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Windows, Linux"
};
---

<BaseLayout
  title={`${siteConfig.name} — Lower-Cost Event Routing`}
  description={homeContent.description}
  canonicalPath="/"
  jsonLd={softwareJsonLd}
>
  <section class="section section--hero">
    <Container>
      <div class="hero-grid">
        <div class="stack">
          <span class="eyebrow">{homeContent.eyebrow}</span>
          <h1 class="hero-title">{homeContent.title}</h1>
          <p class="hero-copy">{homeContent.description}</p>
          <div class="hero-actions">
            <Button href={siteConfig.auth.register.href} variant="primary" icon="arrow-right">
              Start Free
            </Button>
            <Button href="/contact/" variant="secondary" icon="mail">
              Contact
            </Button>
          </div>
          <div class="pill-row">
            {
              homeContent.trustMarks.map((mark) => (
                <span class="status-pill">{mark}</span>
              ))
            }
          </div>
          <RealtimeHeroStats />
          <div class="stats-grid">
            {
              heroTelemetry.map((stat) => (
                <div class="surface-panel">
                  <div class="surface-panel__inner stat-card">
                    <span class="kicker">{stat.label}</span>
                    <strong>{stat.value}</strong>
                    <p>{stat.detail}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <div class="hero-visual">
          <div class="surface-panel hero-proof-card">
            <div class="surface-panel__inner stack">
              <span class="kicker">Why advertisers switch</span>
              <h2 class="hero-proof-card__title">Stop losing signal quality between pixels, tags, plugins, and disconnected tools.</h2>
              <p class="hero-proof-card__copy">
                EventsGateway helps paid-media teams send cleaner purchase and lead events to Meta, Google Ads, and
                TikTok so campaigns learn from better data and optimize against stronger signals.
              </p>
              <ul class="hero-proof-list">
                {
                  heroOutcomes.map((item) => (
                    <li>{item}</li>
                  ))
                }
              </ul>
              <div class="hero-proof-grid">
                <div class="hero-proof-stat">
                  <span>Meta</span>
                  <strong>Higher EMQ</strong>
                  <p>Stronger matching inputs for better optimization and audience quality.</p>
                </div>
                <div class="hero-proof-stat">
                  <span>Mobile</span>
                  <strong>Cleaner tracking</strong>
                  <p>More stable measurement across mobile sessions and iOS-heavy traffic.</p>
                </div>
                <div class="hero-proof-stat">
                  <span>Spend</span>
                  <strong>Lower waste</strong>
                  <p>Reduce bad data, duplicate logic, and tracking gaps that weaken campaign performance.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Positioning"
        title="Built for teams that need control without tracking sprawl."
        description="EventsGateway gives product and growth teams one edge-native control plane for collection, routing, retries, and visibility."
      />
      <div class="card-grid">
        {
          homeContent.problems.map((item) => (
            <PremiumCard icon={item.icon} title={item.title} text={item.text} />
          ))
        }
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <SectionHeader
        eyebrow="Capability Grid"
        title="One commercial layer for collection, routing, and delivery."
        description="Every capability is designed to reduce vendor sprawl, simplify installs, and keep performance marketing operations readable."
      />
      <div class="capability-grid">
        {
          homeContent.capabilities.map((item) => (
            <PremiumCard icon={item.icon} title={item.title} text={item.text} />
          ))
        }
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Pricing"
        title="Free until the first million monthly routed events."
        description="The commercial model is now explicit: up to 1,000,000 routed events per month stay on the Free plan, and every extra 1,000,000-event block adds $5."
      />
      <div class="stats-grid">
        {
          homeContent.pricingHighlights.map((item) => (
            <div class="surface-panel">
              <div class="surface-panel__inner stat-card">
                <span class="kicker">{item.label}</span>
                <strong>{item.value}</strong>
                <p>{item.detail}</p>
              </div>
            </div>
          ))
        }
      </div>
      <p class="pricing-note">{homeContent.pricingFootnote}</p>
      <div class="button-row button-row--center">
        <Button href="/pricing/" variant="primary" icon="arrow-right">Open Pricing</Button>
        <Button href="https://dash.eventsgateway.com/register" variant="secondary" icon="arrow-right">Start Free</Button>
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <div class="two-column">
        <div class="stack">
          <SectionHeader
            eyebrow="Workflow"
            title="A direct path from tracker install to live event routing."
            description="Start with one lightweight integration, route once, and expand destinations only when your stack needs them."
          />
          <ul class="info-list">
            <li>Built for founders, growth teams, ecommerce operators, and product teams.</li>
            <li>Designed to keep implementation readable across both marketing and engineering stakeholders.</li>
            <li>Optimized for low-friction installation and a cost model that starts small.</li>
          </ul>
        </div>
        <div class="timeline">
          {
            homeContent.workflow.map((item) => (
              <PremiumCard class="timeline-card" title={item.title} text={item.text} step={item.step} />
            ))
          }
        </div>
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <SectionHeader
        eyebrow="Control Center"
        title="A product-looking interface for a real event pipeline."
        description="The visual layer reinforces what matters: one collector, clear routing, operational visibility, and a cost model that stays legible as volume grows."
      />
      <CommandCenterMockup instanceId="proof" />
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Commercial Advantage"
        title="Why teams choose EventsGateway over heavier alternatives."
        description="The product story is simple: one setup, lower total cost, cleaner routing, and stronger commercial clarity."
      />
      <div class="triple-grid">
        {
          homeContent.controlColumns.map((item) => (
            <PremiumCard icon={item.icon} title={item.title} text={item.text} />
          ))
        }
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <div class="surface-panel cta-panel">
        <div class="surface-panel__inner stack">
          <span class="eyebrow">Final CTA</span>
          <h2 class="section-title">{homeContent.finalCtaTitle}</h2>
          <p class="section-copy">{homeContent.finalCtaText}</p>
          <div class="button-row">
            <Button href="https://dash.eventsgateway.com/register" variant="primary" icon="arrow-right">Start free</Button>
            <Button href="/contact/" variant="secondary" icon="mail">Contact</Button>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

<script is:inline src="/scripts/window-matrix.js" defer></script>
<script is:inline src="/scripts/hero-realtime.js" defer></script>

<style>
  .stat-card {
    display: grid;
    gap: 0.8rem;
    padding: 1.25rem;
    min-height: 100%;
  }

  .stat-card strong {
    font-family: var(--font-display);
    font-size: 2rem;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .stat-card p {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.55;
  }

  .pricing-note {
    max-width: 62rem;
    margin: 1.25rem auto 0;
    color: var(--color-muted);
    line-height: 1.7;
    text-align: center;
  }

  .button-row--center {
    justify-content: center;
    margin-top: 1.25rem;
  }

  .hero-visual {
    position: relative;
    display: flex;
    align-items: stretch;
  }

  .hero-proof-card {
    width: 100%;
  }

  .hero-proof-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.8vw, 2.35rem);
    letter-spacing: -0.04em;
    line-height: 1.05;
  }

  .hero-proof-card__copy {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .hero-proof-list {
    display: grid;
    gap: 0.8rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hero-proof-list li {
    position: relative;
    padding-left: 1.35rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  .hero-proof-list li::before {
    content: "";
    position: absolute;
    top: 0.58rem;
    left: 0;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: rgba(125, 211, 252, 0.95);
    box-shadow: 0 0 16px rgba(125, 211, 252, 0.45);
  }

  .hero-proof-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .hero-proof-stat {
    display: grid;
    gap: 0.45rem;
    padding: 1rem;
    border: 1px solid rgba(125, 211, 252, 0.14);
    border-radius: 1rem;
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.08), rgba(255, 255, 255, 0.02)),
      rgba(8, 12, 23, 0.9);
  }

  .hero-proof-stat span {
    color: var(--color-subtle);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .hero-proof-stat strong {
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: -0.03em;
  }

  .hero-proof-stat p {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.5;
  }

  @media (max-width: 960px) {
    .hero-proof-grid {
      width: 100%;
      grid-template-columns: 1fr;
    }
  }
</style>
