---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Container from "../components/Container.astro";
import PremiumCard from "../components/PremiumCard.astro";
import RealtimeHeroStats from "../components/RealtimeHeroStats.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { homeContent } from "../content/homepage";
import { siteConfig } from "../config/site";
import { emphasizeBrand } from "../utils/emphasize-brand";

const heroTelemetry = homeContent.stats;
const heroOutcomes = [
  "Use one integration for purchases, leads, and lifecycle events",
  "Route the same event to ads, analytics, and CRM tools",
  "Add destinations without rewriting site code",
  "Keep browser tracking smaller and easier to maintain"
];

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: siteConfig.name,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Windows, Linux"
};
---

<BaseLayout
  title={`${siteConfig.name} — Lower Ad Tracking Cost`}
  description={homeContent.description}
  canonicalPath="/"
  jsonLd={softwareJsonLd}
>
  <section class="section section--hero">
    <Container>
      <div class="stack hero-stack">
        <span class="eyebrow">{homeContent.eyebrow}</span>
        <h1 class="hero-title" set:html={homeContent.title} />
        <p class="hero-copy" set:html={emphasizeBrand(homeContent.description)} />
        <ul class="hero-proof-list">
          {
            heroOutcomes.map((item) => (
              <li>{item}</li>
            ))
          }
        </ul>
        <div class="hero-actions">
          <Button href={siteConfig.auth.register.href} variant="primary" icon="arrow-right">
            Start Free
          </Button>
          <Button href="/contact/" variant="secondary" icon="mail">
            Contact
          </Button>
        </div>
        <div class="pill-row">
          {
            homeContent.trustMarks.map((mark) => (
              <span class="status-pill">{mark}</span>
            ))
          }
        </div>
        <div class="hero-proof-grid">
          <div class="hero-proof-stat">
            <span>Meta</span>
            <strong>Cleaner routing</strong>
            <p>Map canonical events to Meta without adding another separate implementation in the site.</p>
          </div>
          <div class="hero-proof-stat">
            <span>Stack</span>
            <strong>One collection layer</strong>
            <p>Use the same event setup across stores, funnels, landing pages, and product surfaces.</p>
          </div>
          <div class="hero-proof-stat">
            <span>Cost</span>
            <strong>Predictable pricing</strong>
            <p>Start free, then scale in flat 1,000,000-event blocks as routed volume grows.</p>
          </div>
        </div>
        <RealtimeHeroStats />
        <div class="stats-grid hero-stats-grid">
          {
            heroTelemetry.map((stat) => (
              <div class="surface-panel">
                <div class="surface-panel__inner stat-card">
                  <span class="kicker">{stat.label}</span>
                  <strong>{stat.value}</strong>
                  <p>{stat.detail}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Positioning"
        title="Built for teams that want simpler tracking operations."
        description="EVENTS Gateway gives growth and product teams one place to collect, route, and monitor event data without rebuilding the same setup for every tool."
      />
      <div class="card-grid">
        {
          homeContent.problems.map((item) => (
            <PremiumCard icon={item.icon} title={item.title} text={item.text} />
          ))
        }
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <SectionHeader
        eyebrow="Capability Grid"
        title="One setup for routing events across the tools you already use."
        description="Each capability is designed to reduce duplicate work, simplify setup, and keep tracking easier to trust."
      />
      <div class="capability-grid">
        {
          homeContent.capabilities.map((item) => (
            <PremiumCard icon={item.icon} title={item.title} text={item.text} />
          ))
        }
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Pricing"
        title="Free until the first million monthly routed events."
        description="Up to 1,000,000 routed events per month stay on the Free plan, and every extra 1,000,000-event block adds $5."
      />
      <div class="stats-grid">
        {
          homeContent.pricingHighlights.map((item) => (
            <div class="surface-panel">
              <div class="surface-panel__inner stat-card">
                <span class="kicker">{item.label}</span>
                <strong>{item.value}</strong>
                <p>{item.detail}</p>
              </div>
            </div>
          ))
        }
      </div>
      <p class="pricing-note">{homeContent.pricingFootnote}</p>
      <div class="button-row button-row--center">
        <Button href="/pricing/" variant="primary" icon="arrow-right">Open Pricing</Button>
        <Button href="https://dash.eventsgateway.com/register" variant="secondary" icon="arrow-right">Start Free</Button>
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <div class="two-column">
        <div class="stack">
          <SectionHeader
            eyebrow="Workflow"
            title="A simple path from install to usable event routing."
            description="Install once, name events once, and use the same setup across Meta, Google Ads, TikTok, analytics tools, and webhooks."
          />
          <ul class="info-list">
            <li>Fits founders, growth teams, ecommerce operators, and product teams.</li>
            <li>Keeps implementation readable for both marketing and engineering stakeholders.</li>
            <li>Starts with a low-friction install and a pricing model that stays simple.</li>
          </ul>
        </div>
        <div class="timeline">
          {
            homeContent.workflow.map((item) => (
              <PremiumCard class="timeline-card" title={item.title} text={item.text} step={item.step} />
            ))
          }
        </div>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Commercial Advantage"
        title="Why teams choose EVENTS Gateway over more fragmented setups."
        description="The product story is simple: one setup, less duplicate tagging, and a clearer path for routing events across multiple tools."
      />
      <div class="triple-grid">
        {
          homeContent.controlColumns.map((item) => (
            <PremiumCard icon={item.icon} title={item.title} text={item.text} />
          ))
        }
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <div class="surface-panel cta-panel">
        <div class="surface-panel__inner stack">
          <span class="eyebrow">Next Step</span>
          <h2 class="section-title">{homeContent.finalCtaTitle}</h2>
          <p class="section-copy">{homeContent.finalCtaText}</p>
          <div class="button-row">
            <Button href="https://dash.eventsgateway.com/register" variant="primary" icon="arrow-right">Start free</Button>
            <Button href="/contact/" variant="secondary" icon="mail">Contact</Button>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

<script is:inline src="/scripts/window-matrix.js" defer></script>
<script is:inline src="/scripts/hero-realtime.js" defer></script>

<style>
  .stat-card {
    display: grid;
    gap: 0.8rem;
    padding: 1.25rem;
    min-height: 100%;
  }

  .stat-card strong {
    font-family: var(--font-display);
    font-size: 2rem;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .stat-card p {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.55;
  }

  .pricing-note {
    margin: 1.25rem auto 0;
    color: var(--color-muted);
    line-height: 1.7;
    text-align: center;
  }

  .button-row--center {
    justify-content: center;
    margin-top: 1.25rem;
  }

  .hero-stack {
    max-width: 78rem;
    margin-inline: auto;
  }

  .hero-stats-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .hero-proof-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hero-proof-list li {
    position: relative;
    padding-left: 1.35rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  .hero-proof-list li::before {
    content: "";
    position: absolute;
    top: 0.58rem;
    left: 0;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: rgba(125, 211, 252, 0.95);
    box-shadow: 0 0 16px rgba(125, 211, 252, 0.45);
  }

  .hero-proof-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .hero-proof-stat {
    display: grid;
    gap: 0.45rem;
    padding: 1rem;
    border: 1px solid rgba(125, 211, 252, 0.14);
    border-radius: 1rem;
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.08), rgba(255, 255, 255, 0.02)),
      rgba(8, 12, 23, 0.9);
  }

  .hero-proof-stat span {
    color: var(--color-subtle);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .hero-proof-stat strong {
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: -0.03em;
  }

  .hero-proof-stat p {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.5;
  }

  @media (max-width: 960px) {
    .hero-stats-grid,
    .hero-proof-grid {
      width: 100%;
      grid-template-columns: 1fr;
    }

    .hero-proof-list {
      grid-template-columns: 1fr;
    }
  }
</style>
