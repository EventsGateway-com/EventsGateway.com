---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Container from "../components/Container.astro";
import PremiumCard from "../components/PremiumCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { contactContent } from "../content/contact";
---

<BaseLayout
  title="Contact EventsGateway"
  description="General inquiries, private demo requests, and commercial conversations about signal quality, attribution, and growth."
  canonicalPath="/contact/"
>
  <section class="section page-hero">
    <Container>
      <div class="stack">
        <span class="eyebrow">Contact</span>
        <h1 class="page-title">{contactContent.title}</h1>
        <p class="page-copy">{contactContent.intro}</p>
        <p class="small-note">{contactContent.responseTime}</p>
        <div class="pill-row">
          {contactContent.departments.map((item) => <span class="status-pill">{item.label}</span>)}
        </div>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Contact form"
        title="Send the request to the right department."
        description="Use the form to ask about campaign tracking, Meta, Google Ads, TikTok, setup help, pricing, or rollout."
      />
      <div class="two-column contact-form-layout">
        <form id="contact-form" class="surface-panel contact-form-panel" data-contact-form>
          <div class="surface-panel__inner contact-form">
            <label class="contact-field floating-field floating-field--select is-filled" data-floating-field>
              <select id="contact-department" name="department" required>
                {
                  contactContent.departments.map((item) => (
                    <option value={item.value}>{item.label}</option>
                  ))
                }
              </select>
              <span class="floating-label">Department</span>
            </label>
            <label class="contact-field floating-field" data-floating-field>
              <input id="contact-name" name="name" type="text" placeholder=" " required />
              <span class="floating-label">Name</span>
            </label>
            <label class="contact-field floating-field" data-floating-field>
              <input id="contact-email" name="email" type="email" placeholder=" " required />
              <span class="floating-label">Email</span>
            </label>
            <label class="contact-field floating-field" data-floating-field>
              <input id="contact-company" name="company" type="text" placeholder=" " />
              <span class="floating-label">Company</span>
            </label>
            <label class="contact-field floating-field" data-floating-field>
              <input id="contact-website" name="website" type="url" placeholder=" " />
              <span class="floating-label">Website</span>
            </label>
            <label class="contact-field floating-field" data-floating-field>
              <input id="contact-subject" name="subject" type="text" placeholder=" " required />
              <span class="floating-label">Subject</span>
            </label>
            <label class="contact-field contact-field--full floating-field floating-field--textarea" data-floating-field>
              <textarea id="contact-message" name="message" rows="7" placeholder=" " required></textarea>
              <span class="floating-label">Message</span>
            </label>
            <div class="contact-form__actions">
              <Button element="button" type="submit" variant="primary" icon="mail">Send message</Button>
              <p class="small-note" data-contact-status>Messages are delivered through Brevo.</p>
            </div>
          </div>
        </form>
        <div class="contact-grid">
          {
            contactContent.methods.map((item) => (
              <PremiumCard icon={item.icon} title={item.title} text={item.text}>
                <Button href={item.href} variant="secondary" icon="arrow-right">
                  {item.actionLabel}
                </Button>
              </PremiumCard>
            ))
          }
        </div>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <div class="two-column">
        <div>
          <SectionHeader
            eyebrow="Response expectations"
            title="Use one form for every commercial conversation."
            description="Share the ad platforms you use, what you want to improve, and where tracking feels broken today."
          />
          <div class="surface-panel cta-panel">
            <div class="surface-panel__inner stack">
              <span class="kicker">Form-first contact</span>
              <h3 class="contact-focus-title">Use the structured contact form for every inquiry.</h3>
              <p class="section-copy">
                Share your funnel type, paid channels, goals, and current tracking issues so the right team can respond faster.
              </p>
            </div>
          </div>
        </div>
        <div>
          <SectionHeader
            eyebrow="FAQ"
            title="Common questions before the first conversation."
            description="Short answers keep the page helpful without pretending there is functionality that does not exist."
          />
          <div class="stack">
            {
              contactContent.faq.map((item) => (
                <PremiumCard title={item.question} text={item.answer} />
              ))
            }
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <div class="surface-panel cta-panel">
        <div class="surface-panel__inner stack">
          <span class="eyebrow">Private conversations</span>
          <h2 class="section-title">For demos, partnerships, and early access, start with the contact form.</h2>
          <p class="section-copy">
            The form is the public entry point for commercial, support, and growth conversations.
          </p>
          <div class="button-row">
            <Button href="#contact-form" variant="primary" icon="mail">
              Open contact form
            </Button>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .contact-focus-title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2.15rem);
    letter-spacing: -0.03em;
    margin: 0;
  }

  .contact-form-layout {
    align-items: start;
  }

  .contact-form-panel {
    height: 100%;
  }

  .contact-form {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .contact-field--full {
    grid-column: 1 / -1;
  }

  .contact-field input,
  .contact-field select,
  .contact-field textarea {
    width: 100%;
    min-height: 3rem;
    padding: 1.35rem 0.92rem 0.62rem;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: rgba(8, 12, 22, 0.9);
    color: var(--color-text);
  }

  .contact-field textarea {
    min-height: 10rem;
    resize: vertical;
  }

  .contact-form__actions {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }

  @media (max-width: 720px) {
    .contact-form {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline src="/scripts/contact-form.js" defer></script>
