---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Container from "../components/Container.astro";
import PremiumCard from "../components/PremiumCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { contactContent } from "../content/contact";
---

<BaseLayout
  title="Contact EventsGateway"
  description="General inquiries, private demo requests, and technical partnership contact paths."
  canonicalPath="/contact/"
>
  <section class="section page-hero">
    <Container>
      <div class="two-column">
        <div class="stack">
          <span class="eyebrow">Enterprise contact</span>
          <h1 class="page-title">{contactContent.title}</h1>
          <p class="page-copy">{contactContent.intro}</p>
          <p class="small-note">{contactContent.responseTime}</p>
        </div>
        <div class="surface-panel cta-panel">
          <div class="surface-panel__inner stack">
            <span class="kicker">Departments</span>
            <ul class="simple-list">
              {contactContent.departments.map((item) => <li><strong>{item.label}</strong> - {item.detail}</li>)}
            </ul>
            <p class="small-note">{contactContent.confidentialityNote}</p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Contact form"
        title="Send the request to the right department."
        description="This form sends the inquiry through Brevo so the team receives structured contact requests without exposing direct inbox handling in the UI."
      />
      <div class="two-column contact-form-layout">
        <form id="contact-form" class="surface-panel contact-form-panel" data-contact-form>
          <div class="surface-panel__inner contact-form">
            <label class="contact-field">
              <span>Department</span>
              <select name="department" required>
                {
                  contactContent.departments.map((item) => (
                    <option value={item.value}>{item.label}</option>
                  ))
                }
              </select>
            </label>
            <label class="contact-field">
              <span>Name</span>
              <input name="name" type="text" required />
            </label>
            <label class="contact-field">
              <span>Email</span>
              <input name="email" type="email" required />
            </label>
            <label class="contact-field">
              <span>Company</span>
              <input name="company" type="text" />
            </label>
            <label class="contact-field">
              <span>Website</span>
              <input name="website" type="url" placeholder="https://example.com" />
            </label>
            <label class="contact-field">
              <span>Subject</span>
              <input name="subject" type="text" required />
            </label>
            <label class="contact-field contact-field--full">
              <span>Message</span>
              <textarea name="message" rows="7" required></textarea>
            </label>
            <div class="contact-form__actions">
              <Button element="button" type="submit" variant="primary" icon="mail">Send message</Button>
              <p class="small-note" data-contact-status>Messages are delivered through Brevo.</p>
            </div>
          </div>
        </form>
        <div class="contact-grid">
          {
            contactContent.methods.map((item) => (
              <PremiumCard icon={item.icon} title={item.title} text={item.text}>
                <Button href={item.href} variant="secondary" icon="arrow-right">
                  {item.actionLabel}
                </Button>
              </PremiumCard>
            ))
          }
        </div>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <div class="two-column">
        <div>
          <SectionHeader
            eyebrow="Response expectations"
            title="Designed to feel like an enterprise inquiry flow."
            description="The page gives enough structure to support serious outreach through a live backend delivery path."
          />
          <div class="surface-panel cta-panel">
            <div class="surface-panel__inner stack">
              <span class="kicker">Form-first contact</span>
              <h3 class="contact-focus-title">Use the structured contact form for every inquiry.</h3>
              <p class="section-copy">
                Share product context, deployment posture, timing, and the destination mix you need so the right department receives the request.
              </p>
            </div>
          </div>
        </div>
        <div>
          <SectionHeader
            eyebrow="FAQ"
            title="Common questions before the first conversation."
            description="Short answers keep the page helpful without pretending there is functionality that does not exist."
          />
          <div class="stack">
            {
              contactContent.faq.map((item) => (
                <PremiumCard title={item.question} text={item.answer} />
              ))
            }
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <div class="surface-panel cta-panel">
        <div class="surface-panel__inner stack">
          <span class="eyebrow">Private conversations</span>
          <h2 class="section-title">For demos, partnerships, and early access, start with the contact form.</h2>
          <p class="section-copy">
            The form is the public entry point for commercial, support, and technical conversations.
          </p>
          <div class="button-row">
            <Button href="#contact-form" variant="primary" icon="mail">
              Open contact form
            </Button>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .contact-focus-title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2.15rem);
    letter-spacing: -0.03em;
    margin: 0;
  }

  .contact-form-layout {
    align-items: start;
  }

  .contact-form-panel {
    height: 100%;
  }

  .contact-form {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .contact-field {
    display: grid;
    gap: 0.45rem;
    color: var(--color-muted);
  }

  .contact-field--full {
    grid-column: 1 / -1;
  }

  .contact-field input,
  .contact-field select,
  .contact-field textarea {
    width: 100%;
    min-height: 3rem;
    padding: 0.82rem 0.92rem;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: rgba(8, 12, 22, 0.9);
    color: var(--color-text);
  }

  .contact-field textarea {
    min-height: 10rem;
    resize: vertical;
  }

  .contact-form__actions {
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }

  @media (max-width: 720px) {
    .contact-form {
      grid-template-columns: 1fr;
    }
  }
</style>

<script src="/scripts/contact-form.js" defer></script>
