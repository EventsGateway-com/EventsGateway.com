---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Container from "../components/Container.astro";
import PremiumCard from "../components/PremiumCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { installGuideContent } from "../content/install-guide";
import { siteConfig } from "../config/site";

const repositoryUrl = siteConfig.social.github;
const repositoryConfigured = Boolean(repositoryUrl);

const installJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "Install EventsGateway on your domain",
  description:
    "A step by step guide to deploy EventsGateway from the GitHub repository to Cloudflare Workers and connect it to a live domain.",
  step: installGuideContent.steps.map((item) => ({
    "@type": "HowToStep",
    name: item.title,
    text: item.text
  }))
};
---

<BaseLayout
  title={`Install ${siteConfig.name} On Your Domain`}
  description="Step by step guide for installing EventsGateway from the GitHub repository to Cloudflare Workers on a real domain."
  canonicalPath="/install/"
  jsonLd={installJsonLd}
>
  <section class="section page-hero">
    <Container>
      <div class="stack">
        <span class="eyebrow">{installGuideContent.eyebrow}</span>
        <h1 class="page-title">{installGuideContent.title}</h1>
        <p class="page-copy">{installGuideContent.intro}</p>
        <div class="button-row">
          {
            repositoryConfigured ? (
              <Button href={repositoryUrl} variant="primary" icon="arrow-right">Open GitHub Repository</Button>
            ) : (
              <Button variant="primary" icon="arrow-right" disabled>Set GitHub Repository URL</Button>
            )
          }
          <Button href="/install/" variant="secondary" icon="download">Install Overview</Button>
        </div>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Preflight"
        title="What you need before you start."
        description="The installation path is intentionally direct: start from GitHub, deploy the Workers runtime, and attach the tracker to the site you already own."
      />
      <div class="card-grid">
        {
          installGuideContent.preflight.map((item) => (
            <PremiumCard icon="check" title={item.title} text={item.text} />
          ))
        }
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <div class="two-column">
        <div class="stack">
          <SectionHeader
            eyebrow="Installation Flow"
            title="From GitHub page to live domain."
            description="These steps describe the simplest operational path for a team that wants to deploy EventsGateway on its own Cloudflare account."
          />
          <ul class="info-list">
            <li>The public website can stay on its own domain while the event collector runs on a dedicated subdomain.</li>
            <li>The tracker can be added to marketing sites, stores, landing pages, and custom applications.</li>
            <li>The same Cloudflare Workers runtime can receive events from multiple pages or products.</li>
          </ul>
        </div>
        <div class="timeline">
          {
            installGuideContent.steps.map((item) => (
              <PremiumCard class="timeline-card" title={item.title} text={item.text} step={item.step} />
            ))
          }
        </div>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Command Path"
        title="Run the core installation commands."
        description="These command blocks mirror the shortest path from the repository to a working Cloudflare Workers deployment and tracker install."
      />
      <div class="command-grid">
        {
          installGuideContent.commandBlocks.map((item) => (
            <div class="surface-panel command-panel">
              <div class="surface-panel__inner stack">
                <span class="kicker">{item.title}</span>
                <pre class="command-block"><code>{item.code}</code></pre>
              </div>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Domain Example"
        title="A simple production layout."
        description="Use separate hostnames so the event entry point is explicit and easy to manage."
      />
      <div class="card-grid">
        <PremiumCard
          icon="cloud"
          title={installGuideContent.domainExample.appDomain}
          text="Your public site. This can stay on any frontend stack as long as you can add the tracker snippet."
          eyebrow="Public site"
        />
        <PremiumCard
          icon="terminal"
          title={installGuideContent.domainExample.collectorDomain}
          text="Your Cloudflare Workers collector endpoint. The tracker sends events here first."
          eyebrow="Collector"
        />
        <PremiumCard
          icon="layers"
          title={installGuideContent.domainExample.apiDomain}
          text="Optional management API hostname for dashboard calls and operational tooling."
          eyebrow="API"
        />
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Install Wizard"
        title="Generate the private setup values before deployment."
        description="This initial install flow lives on the public root domain and helps self-hosted users replace the default official Cloudflare and captcha values with their own deployment settings."
      />
      <div class="wizard-grid" data-install-wizard>
        <div class="surface-panel wizard-panel">
          <div class="surface-panel__inner stack wizard-form">
            <label class="wizard-field">
              <span>Root domain</span>
              <input id="install-root-domain" type="text" value="example.com" />
            </label>
            <label class="wizard-field">
              <span>Dashboard domain</span>
              <input id="install-dashboard-domain" type="text" value="dash.example.com" />
            </label>
            <label class="wizard-field">
              <span>API domain</span>
              <input id="install-api-domain" type="text" value="api.example.com" />
            </label>
            <label class="wizard-field">
              <span>Collector domain</span>
              <input id="install-collector-domain" type="text" value="events.example.com" />
            </label>
            <label class="wizard-field">
              <span>Cloudflare account ID</span>
              <input id="install-account-id" type="text" value="" />
            </label>
            <label class="wizard-field">
              <span>Cloudflare zone ID</span>
              <input id="install-zone-id" type="text" value="" />
            </label>
            <label class="wizard-field">
              <span>D1 database ID</span>
              <input id="install-database-id" type="text" value="" />
            </label>
            <label class="wizard-field">
              <span>D1 database name</span>
              <input id="install-database-name" type="text" value="eventsgateway-control-plane" />
            </label>
            <label class="wizard-field">
              <span>Queue name</span>
              <input id="install-queue-name" type="text" value="eventsgateway-ingest" />
            </label>
          </div>
        </div>

        <div class="surface-panel wizard-panel">
          <div class="surface-panel__inner stack wizard-form">
            <label class="wizard-field">
              <span>Captcha provider</span>
              <select id="install-captcha-provider">
                <option value="turnstile">Cloudflare Turnstile</option>
                <option value="recaptcha">Google reCAPTCHA</option>
                <option value="hcaptcha">hCaptcha</option>
              </select>
            </label>
            <label class="wizard-field">
              <span>Captcha site key</span>
              <input id="install-captcha-site-key" type="text" value="" />
            </label>
            <label class="wizard-field">
              <span>Captcha secret key</span>
              <input id="install-captcha-secret-key" type="password" value="" />
            </label>
            <label class="wizard-field">
              <span>Stripe publishable key</span>
              <input id="install-stripe-publishable-key" type="text" value="" />
            </label>
            <label class="wizard-field">
              <span>Stripe secret key</span>
              <input id="install-stripe-secret-key" type="password" value="" />
            </label>
            <label class="wizard-field">
              <span>Stripe webhook secret</span>
              <input id="install-stripe-webhook-secret" type="password" value="" />
            </label>
            <div class="wizard-note">
              The official repository ships with deployment defaults for the hosted EventsGateway instance. Replace them in your own copy during install.
            </div>
            <div class="wizard-note">
              The secret key must stay only in private local files, CI secrets, or Cloudflare secret storage.
            </div>
            <div class="wizard-note">
              Stripe keeps card data off your infrastructure. EventsGateway stores billing state, invoices, reminders, and suspension controls, while Stripe handles sensitive payment details.
            </div>
          </div>
        </div>
      </div>

      <div class="command-grid wizard-output-grid">
        <div class="surface-panel command-panel">
          <div class="surface-panel__inner stack">
            <span class="kicker">Dashboard Public Env</span>
            <pre class="command-block"><code id="install-output-dashboard-env"></code></pre>
          </div>
        </div>
        <div class="surface-panel command-panel">
          <div class="surface-panel__inner stack">
            <span class="kicker">API Private Env</span>
            <pre class="command-block"><code id="install-output-api-env"></code></pre>
          </div>
        </div>
        <div class="surface-panel command-panel">
          <div class="surface-panel__inner stack">
            <span class="kicker">Tracked Placeholder Map</span>
            <pre class="command-block"><code id="install-output-placeholders"></code></pre>
          </div>
        </div>
        <div class="surface-panel command-panel">
          <div class="surface-panel__inner stack">
            <span class="kicker">Private Deployment Values</span>
            <pre class="command-block"><code id="install-output-private-values"></code></pre>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <div class="two-column">
        <div class="surface-panel cta-panel">
          <div class="surface-panel__inner stack">
            <span class="kicker">GitHub Start</span>
            <h2 class="section-title">Start from the repository, not from a blank setup.</h2>
            <p class="section-copy">
              Clone the project from GitHub, deploy the Workers runtime on Cloudflare, then connect your domain and
              add the tracker snippet to the target site.
            </p>
            {
              repositoryConfigured ? (
                <a class="repository-link" href={repositoryUrl}>{repositoryUrl}</a>
              ) : (
                <p class="repository-note">
                  Add the public repository URL in <code>src/config/site.ts</code> to expose the direct GitHub link here.
                </p>
              )
            }
          </div>
        </div>
        <div class="surface-panel cta-panel">
          <div class="surface-panel__inner stack">
            <span class="kicker">Readiness Checklist</span>
            <ul class="simple-list">
              {installGuideContent.checklist.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .command-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .wizard-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .wizard-panel {
    height: 100%;
  }

  .wizard-form {
    gap: 0.9rem;
  }

  .wizard-field {
    display: grid;
    gap: 0.45rem;
    color: var(--color-muted);
  }

  .wizard-field span {
    font-size: 0.85rem;
  }

  .wizard-field input,
  .wizard-field select {
    min-height: 3rem;
    padding: 0.8rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 0.9rem;
    background: rgba(5, 10, 24, 0.9);
    color: var(--color-text);
  }

  .wizard-note {
    padding: 0.9rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.03);
    color: var(--color-muted);
    line-height: 1.7;
  }

  .wizard-output-grid {
    margin-top: 1rem;
  }

  .command-panel {
    height: 100%;
  }

  .command-block {
    margin: 0;
    padding: 1rem;
    overflow-x: auto;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: rgba(5, 10, 24, 0.9);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.7;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .repository-link,
  .repository-note {
    display: inline-flex;
    align-items: center;
    min-height: 3rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-muted);
    line-height: 1.6;
    word-break: break-all;
  }

  .repository-link:hover {
    border-color: rgba(125, 211, 252, 0.35);
    color: var(--color-text);
  }

  .repository-note code {
    font-family: var(--font-mono);
    color: var(--color-text);
  }

  @media (max-width: 900px) {
    .wizard-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline src="/scripts/install-wizard.js"></script>
