---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Container from "../components/Container.astro";
import PremiumCard from "../components/PremiumCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { pricingContent } from "../content/pricing";
import { siteConfig } from "../config/site";

const pricingJsonLd = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  name: `${siteConfig.name} pricing`,
  itemListElement: pricingContent.plans.map((plan) => ({
    "@type": "Offer",
    name: plan.name,
    description: plan.highlight,
    price: plan.price.replace(/[^0-9.]/g, "") || "0",
    priceCurrency: "USD"
  }))
};
---

<BaseLayout
  title={`Pricing - ${siteConfig.name}`}
  description="Transparent EVENTS Gateway pricing with a free 1,000,000 event allowance, $5 per extra 1,000,000 events, and Enterprise plans starting at $1,995 per month."
  canonicalPath="/pricing/"
  jsonLd={pricingJsonLd}
>
  <section class="section page-hero">
    <Container>
      <div class="stack">
        <span class="eyebrow">{pricingContent.eyebrow}</span>
        <h1 class="page-title">{pricingContent.title}</h1>
        <p class="page-copy">{pricingContent.intro}</p>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <div class="card-grid">
        {
          pricingContent.plans.map((plan) => (
            <PremiumCard icon="layers" title={plan.name} text={plan.highlight} eyebrow="Plan">
              <div class="pricing-plan">
                <div class="pricing-plan__price">
                  <strong>{plan.price}</strong>
                  <span>{plan.cadence}</span>
                </div>
                <ul class="simple-list">
                  {plan.features.map((feature) => <li>{feature}</li>)}
                </ul>
                {plan.name === "Enterprise" && (
                  <div style="margin-top: auto; padding-top: 1rem;">
                    <Button href="/contact/" variant="secondary" icon="mail">Talk to us</Button>
                  </div>
                )}
              </div>
            </PremiumCard>
          ))
        }
      </div>
      <div class="ml-plan-wrapper">
        <PremiumCard icon="spark" eyebrow="Add-on" class="ml-plan-card" href="https://dash.eventsgateway.com/register">
          <div class="ml-plan-content">
            <div class="ml-plan-info">
              <h3>Machine Learning</h3>
              <p>Enriched events for Meta/Google/Tiktok with predicted data</p>
            </div>
            <div class="pricing-plan__price">
              <strong>$295</strong>
              <span>/ site with unlimited events</span>
            </div>
          </div>
        </PremiumCard>
      </div>
    </Container>
  </section>

  <section class="section">
    <Container>
      <div class="two-column pricing-layout">
        <div class="stack">
          <SectionHeader
            eyebrow="Calculator"
            title="Estimate your monthly bill in seconds."
            description="Use the calculator to see how the free allowance and linear overage work for your expected monthly routed volume."
          />
          <div class="surface-panel">
            <div class="surface-panel__inner pricing-calculator" data-pricing-calculator>
              <label class="pricing-field pricing-field--range">
                <span>Estimated monthly routed events per site</span>
                <input id="pricing-events" type="range" min="0" max="20000000" step="50000" value="1000000" />
                <div class="pricing-range-scale" aria-hidden="true">
                  <span>0</span>
                  <span>20,000,000</span>
                </div>
              </label>
              <label class="pricing-field floating-field" data-floating-field>
                <input id="pricing-events-input" type="number" min="0" step="1000" value="1000000" placeholder=" " />
                <span class="floating-label">Exact value</span>
              </label>
              <div class="pricing-summary-grid">
                <div class="pricing-summary-card">
                  <span>Selected volume</span>
                  <strong id="pricing-selected">1,000,000</strong>
                </div>
                <div class="pricing-summary-card">
                  <span>Estimated monthly bill</span>
                  <strong id="pricing-total">$0</strong>
                </div>
              </div>
              <div class="pricing-breakdown">
                <div><span>Included</span><strong id="pricing-included">1,000,000</strong></div>
                <div><span>Billing rule</span><strong>$5 per extra 1M events</strong></div>
              </div>
            </div>
          </div>
        </div>

        <div class="stack">
          <SectionHeader
            eyebrow="What Is Included"
            title="No ambiguity around the Free plan."
            description="This is what you get when you want to launch quickly and keep ad tracking costs easy to understand."
          />
          <div class="card-grid">
            {
              pricingContent.included.map((item) => (
                <PremiumCard icon="check" title={item} text="Included in the product and commercial model from the first signup." />
              ))
            }
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="section section--tight">
    <Container>
      <SectionHeader
        eyebrow="Billing Rules"
        title="How overage billing works."
        description="The goal is simple: easy pricing, no surprises, and no steep jump when volume grows."
      />
      <div class="card-grid">
        {
          pricingContent.footnotes.map((item, index) => (
            <PremiumCard icon="terminal" title={`Rule ${index + 1}`} text={item} />
          ))
        }
      </div>
      <div class="button-row button-row--center">
        <Button href="https://dash.eventsgateway.com/register" variant="primary" icon="arrow-right">Create free account</Button>
        <Button href="https://dash.eventsgateway.com/login" variant="secondary" icon="arrow-right">Go to Billing Dashboard</Button>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .ml-plan-wrapper {
    margin-top: 0.82rem;
  }

  .ml-plan-content {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .ml-plan-info h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: -0.02em;
  }

  .ml-plan-info p {
    margin: 0.25rem 0 0;
    color: var(--color-muted);
    line-height: 1.65;
  }

  @media (min-width: 961px) {
    .ml-plan-card :global(.premium-card__inner) {
      flex-direction: row;
      align-items: center;
      padding: 1.5rem;
      gap: 2rem;
    }

    .ml-plan-card :global(.premium-card__header) {
      flex-shrink: 0;
    }

    .ml-plan-content {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      gap: 2rem;
    }
  }

  .pricing-plan {
    display: grid;
    gap: 1rem;
  }

  .pricing-plan__price {
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
  }

  .pricing-plan__price strong {
    font-family: var(--font-display);
    font-size: 2.4rem;
    letter-spacing: -0.05em;
  }

  .pricing-plan__price span {
    color: var(--color-muted);
  }

  .pricing-layout {
    align-items: start;
  }

  .pricing-calculator {
    display: grid;
    gap: 1rem;
    padding: 1.35rem;
  }

  .pricing-field {
    display: grid;
    gap: 0.5rem;
    color: var(--color-muted);
  }

  .pricing-field--range > span {
    font-size: 0.85rem;
  }

  .pricing-field input[type="range"],
  .pricing-field input[type="number"] {
    width: 100%;
    min-height: 3rem;
    color: var(--color-text);
  }

  .pricing-field input[type="number"] {
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: rgba(5, 10, 24, 0.9);
  }

  .pricing-field input[type="range"] {
    min-height: 1.25rem;
    padding: 0;
    border: 0;
    border-radius: 999px;
    appearance: none;
    -webkit-appearance: none;
    background:
      linear-gradient(90deg, rgba(125, 211, 252, 0.95) 0%, rgba(125, 211, 252, 0.95) var(--range-progress, 5%), rgba(255, 255, 255, 0.12) var(--range-progress, 5%), rgba(255, 255, 255, 0.12) 100%);
    outline: none;
    cursor: pointer;
  }

  .pricing-field input[type="range"]::-webkit-slider-runnable-track {
    height: 0.5rem;
    border-radius: 999px;
    background: transparent;
  }

  .pricing-field input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 1.15rem;
    height: 1.15rem;
    margin-top: -0.325rem;
    border: 0;
    border-radius: 999px;
    background: #d8f3ff;
    box-shadow: 0 0 0 4px rgba(125, 211, 252, 0.22);
  }

  .pricing-field input[type="range"]::-moz-range-track {
    height: 0.5rem;
    border: 0;
    border-radius: 999px;
    background: transparent;
  }

  .pricing-field input[type="range"]::-moz-range-progress {
    height: 0.5rem;
    border-radius: 999px;
    background: rgba(125, 211, 252, 0.95);
  }

  .pricing-field input[type="range"]::-moz-range-thumb {
    width: 1.15rem;
    height: 1.15rem;
    border: 0;
    border-radius: 999px;
    background: #d8f3ff;
    box-shadow: 0 0 0 4px rgba(125, 211, 252, 0.22);
  }

  .pricing-range-scale {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: var(--color-subtle);
    font-size: 0.78rem;
  }

  .pricing-summary-grid {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .pricing-summary-card,
  .pricing-breakdown div {
    display: grid;
    gap: 0.3rem;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.03);
  }

  .pricing-summary-card span,
  .pricing-breakdown span {
    color: var(--color-subtle);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .pricing-summary-card strong {
    font-family: var(--font-display);
    font-size: 1.6rem;
    letter-spacing: -0.04em;
  }

  .pricing-breakdown {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .button-row--center {
    justify-content: center;
    margin-top: 1.15rem;
  }

  @media (max-width: 960px) {
    .pricing-summary-grid,
    .pricing-breakdown {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline src="/scripts/pricing-calculator.js" defer></script>
