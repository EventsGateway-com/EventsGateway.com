---
import { siteConfig } from "../config/site";

const { showTagline = true } = Astro.props as {
  showTagline?: boolean;
};
---

<a class="brand" href="/" aria-label={`${siteConfig.name} home`}>
  <img src="/eventsgateway-icon-symbol-only.svg" alt="EventsGateway" width="56" height="56" />
  <span class="brand__text">
    <strong>EVENTS<br />Gateway</strong>
    {showTagline && <small>{siteConfig.tagline}</small>}
  </span>
</a>

<style>
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.82rem;
    min-width: 0;
  }

  .brand__text {
    display: grid;
    gap: 0.14rem;
    min-width: 0;
  }

  .brand strong {
    font-family: var(--font-display);
    font-size: 1.12rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .brand small {
    display: block;
    max-width: 24ch;
    color: var(--color-subtle);
    font-size: 0.76rem;
    line-height: 1.35;
  }

  @media (max-width: 720px) {
    .brand small {
      display: none;
    }
  }
</style>
