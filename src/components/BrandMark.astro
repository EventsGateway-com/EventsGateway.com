---
import Icon from "./Icon.astro";
import { siteConfig } from "../config/site";

const { showTagline = true } = Astro.props as {
  showTagline?: boolean;
};
---

<a class="brand" href="/" aria-label={`${siteConfig.name} home`}>
  <span class="brand__glyph">
    <img src="/eventsgateway-icon-symbol-only.svg" alt="EventsGateway" width="26" height="26" />
  </span>
  <span class="brand__text">
    <strong>{siteConfig.name}</strong>
    {showTagline && <small>{siteConfig.tagline}</small>}
  </span>
</a>

<style>
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.82rem;
    min-width: 0;
  }

  .brand__glyph {
    width: 2.85rem;
    height: 2.85rem;
    display: grid;
    place-items: center;
    border-radius: 0.95rem;
    border: 1px solid rgba(125, 211, 252, 0.28);
    background:
      linear-gradient(140deg, rgba(125, 211, 252, 0.28), rgba(167, 139, 250, 0.22)),
      rgba(255, 255, 255, 0.05);
    color: var(--color-text);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .brand__text {
    display: grid;
    gap: 0.14rem;
    min-width: 0;
  }

  .brand strong {
    font-family: var(--font-display);
    font-size: 1.12rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .brand small {
    display: block;
    max-width: 24ch;
    color: var(--color-subtle);
    font-size: 0.76rem;
    line-height: 1.35;
  }

  @media (max-width: 720px) {
    .brand small {
      display: none;
    }
  }
</style>
