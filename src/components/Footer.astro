---
import BrandMark from "./BrandMark.astro";
import Container from "./Container.astro";
import { siteConfig } from "../config/site";

const commercialLinks = [
  { label: "Pricing", href: "/pricing/" },
  { label: "Integrations", href: "/integrations/" },
  { label: "Dashboard", href: "https://dash.eventsgateway.com/login", external: true },
  { label: "Contact", href: "/contact/" },
  { label: "Founder", href: "/founder/" }
];

const openSourceLinks = [
  { label: "Docs", href: "/docs/" },
  { label: "Install", href: "/install/" },
  { label: "Status", href: "/status/" },
  { label: "Compare", href: "/compare/" },
  { label: "Open Source", href: "/open-source/" },
  { label: "GitHub", href: siteConfig.social.github, external: true }
];
---

<footer class="site-footer section section--tight">
  <Container>
    <div class="site-footer__grid">
      <div class="site-footer__brand stack">
        <BrandMark />
        <p class="small-note">{siteConfig.footerStatus}</p>
      </div>
      <nav class="site-footer__column" aria-label="Commercial">
        <span class="site-footer__label">Commercial</span>
        {
          commercialLinks.map((item) => (
            <a href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noreferrer" : undefined}>{item.label}</a>
          ))
        }
      </nav>
      <nav class="site-footer__column" aria-label="Open source">
        <span class="site-footer__label">Open source</span>
        {
          openSourceLinks.map((item) => (
            <a href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noreferrer" : undefined}>{item.label}</a>
          ))
        }
      </nav>
      <div class="site-footer__meta">
        <p class="small-note">Use the contact form for all product, commercial, support, and partnership requests.</p>
        <p class="small-note">&copy; {new Date().getFullYear()} {siteConfig.name}. Open source public site.</p>
      </div>
    </div>
  </Container>
</footer>

<style>
  .site-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin-top: 2rem;
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) repeat(2, minmax(0, 0.8fr)) minmax(0, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .site-footer__brand {
    max-width: 30rem;
  }

  .site-footer__brand :global(.brand) {
    align-items: flex-start;
  }

  .site-footer__column {
    display: grid;
    gap: 0.7rem;
  }

  .site-footer__label {
    color: var(--color-subtle);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .site-footer__column a {
    color: var(--color-muted);
    transition: color 180ms ease;
  }

  .site-footer__column a:hover {
    color: var(--color-text);
  }

  .site-footer__meta {
    display: grid;
    gap: 0.75rem;
  }

  @media (max-width: 900px) {
    .site-footer__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
