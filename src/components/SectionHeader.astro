---
import { emphasizeBrand, emphasizeBrandInHtml } from "../utils/emphasize-brand";

const {
  eyebrow,
  title,
  description,
  titleHtml,
  descriptionHtml,
  align = "left",
  class: className = ""
} = Astro.props as {
  eyebrow?: string;
  title: string;
  description?: string;
  titleHtml?: string;
  descriptionHtml?: string;
  align?: "left" | "center";
  class?: string;
};

const resolvedTitleHtml = titleHtml ? emphasizeBrandInHtml(titleHtml) : emphasizeBrand(title);
const resolvedDescriptionHtml = descriptionHtml ? emphasizeBrandInHtml(descriptionHtml) : emphasizeBrand(description);
---

<div class:list={["content-lead", align === "center" && "content-lead--center", className]}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  {resolvedTitleHtml ? <h2 class="section-title" set:html={resolvedTitleHtml} /> : <h2 class="section-title">{title}</h2>}
  {resolvedDescriptionHtml ? <p class="section-copy" set:html={resolvedDescriptionHtml} /> : description && <p class="section-copy">{description}</p>}
</div>

<style>
  .content-lead--center {
    justify-items: center;
    text-align: center;
  }

  .content-lead--center .section-title,
  .content-lead--center .section-copy {
    max-width: 20ch;
  }
  .content-lead--center .section-copy {
    max-width: 38rem;
  }
</style>
