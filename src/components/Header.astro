---
import BrandMark from "./BrandMark.astro";
import Button from "./Button.astro";
import Container from "./Container.astro";
import { siteConfig } from "../config/site";
import { docsContent } from "../content/docs";
import { comparePages } from "../content/compare-pages";
import { integrationsContent } from "../content/integrations";

const pathname = Astro.url.pathname;
const coreLinks = [
  { label: "Home", href: "/" },
  { label: "Pricing", href: "/pricing/" }
];
const docsLinks = [
  { label: "Docs Home", href: "/docs/" },
  ...docsContent.sections.map((section) => ({
    label: section.title,
    href: section.href
  }))
];
const compareLinks = [
  { label: "Compare Home", href: "/compare/" },
  { label: "Why Not Direct Pixels", href: "/why-not-direct-pixels/" },
  ...Object.entries(comparePages).map(([slug, page]) => ({
    label: slug === "cloudflare-zaraz" ? "Zaraz" : page.title.replace("EVENTS Gateway vs ", ""),
    href: `/compare/${slug}/`
  }))
] as Array<{ label: string; href: string }>;
const integrationsLinks = [
  { label: "Integrations Home", href: "/integrations/" },
  ...integrationsContent.items.map((item) => ({
    label: item.label,
    href: `/integrations/${item.slug}/`
  }))
] as Array<{ label: string; href: string }>;
const integrationsCountLabel = `Integrations (${integrationsContent.items.length})`;
const communityLinks = [
  { label: "Open Source", href: "/open-source/" },
  { label: "Install", href: "/install/" },
  { label: "Status", href: "/status/" },
  { label: "GitHub", href: siteConfig.social.github, external: true }
];
const contactLinks = [
  { label: "Contact", href: "/contact/" },
  { label: "Founder", href: "/founder/" }
];

function isActivePath(href: string) {
  if (href === "/") {
    return pathname === "/";
  }
  if (href === "/docs/") {
    return pathname.startsWith("/docs/");
  }
  if (href === "/compare/") {
    return pathname.startsWith("/compare/") || pathname === "/why-not-direct-pixels/";
  }
  return pathname === href || pathname.startsWith(href);
}

const docsActive = pathname.startsWith("/docs/");
const compareActive = pathname.startsWith("/compare/") || pathname === "/why-not-direct-pixels/";
const integrationsActive = pathname.startsWith("/integrations/");
const communityActive = pathname.startsWith("/open-source/") || pathname.startsWith("/install/") || pathname.startsWith("/status/");
const contactActive = pathname.startsWith("/contact/") || pathname.startsWith("/founder/");
---

<header class="site-header">
  <Container class="site-header__frame">
    <div class="site-header__inner">
      <BrandMark showTagline={false} />
      <div class="desktop-nav-shell">
        <nav class="desktop-nav" aria-label="Primary">
          {
            coreLinks.map((item) => (
              <a class:list={["nav-link", isActivePath(item.href) && "is-active"]} href={item.href}>
                <span class="nav-link__dot"></span>
                {item.label}
              </a>
            ))
          }
          <details class:list={["nav-dropdown", docsActive && "is-active"]}>
            <summary class="nav-link">
              <span class="nav-link__dot"></span>
              Docs
            </summary>
            <div class="nav-dropdown__panel nav-dropdown__panel--wide nav-dropdown__panel--scroll">
              {
                docsLinks.map((item) => (
                  <a class:list={[isActivePath(item.href) && "is-active"]} href={item.href}>
                    {item.label}
                  </a>
                ))
              }
            </div>
          </details>
          <details class:list={["nav-dropdown", compareActive && "is-active"]}>
            <summary class="nav-link">
              <span class="nav-link__dot"></span>
              Compare
            </summary>
            <div class="nav-dropdown__panel nav-dropdown__panel--wide nav-dropdown__panel--scroll">
              {
                compareLinks.map((item) => (
                  <a class:list={[isActivePath(item.href) && "is-active"]} href={item.href}>
                    {item.label}
                  </a>
                ))
              }
            </div>
          </details>
          <details class:list={["nav-dropdown", integrationsActive && "is-active"]}>
            <summary class="nav-link">
              <span class="nav-link__dot"></span>
              {integrationsCountLabel}
            </summary>
            <div class="nav-dropdown__panel nav-dropdown__panel--wide nav-dropdown__panel--scroll">
              {
                integrationsLinks.map((item) => (
                  <a class:list={[isActivePath(item.href) && "is-active"]} href={item.href}>
                    {item.label}
                  </a>
                ))
              }
            </div>
          </details>
          <details class:list={["nav-dropdown", communityActive && "is-active"]}>
            <summary class="nav-link">
              <span class="nav-link__dot"></span>
              Community
            </summary>
            <div class="nav-dropdown__panel">
              {
                communityLinks.map((item) => (
                  <a class:list={[isActivePath(item.href) && "is-active"]} href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noreferrer" : undefined}>
                    {item.label}
                  </a>
                ))
              }
            </div>
          </details>
          <details class:list={["nav-dropdown", contactActive && "is-active"]}>
            <summary class="nav-link">
              <span class="nav-link__dot"></span>
              Contact
            </summary>
            <div class="nav-dropdown__panel">
              {
                contactLinks.map((item) => (
                  <a href={item.href}>{item.label}</a>
                ))
              }
            </div>
          </details>
        </nav>
      </div>
      <div class="desktop-cta">
        <Button href={siteConfig.auth.login.href} variant="secondary" icon="arrow-right">
          Dashboard
        </Button>
      </div>
    <details class="mobile-nav">
      <summary aria-label="Open navigation menu">
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div class="mobile-nav__panel">
        <nav aria-label="Mobile">
          {
            coreLinks.map((item) => (
              <a class:list={["mobile-link", isActivePath(item.href) && "is-active"]} href={item.href}>
                <span class="nav-link__dot"></span>
                {item.label}
              </a>
            ))
          }
          <details class="mobile-nav__group">
            <summary class="mobile-nav__label">
              Docs
              <svg aria-hidden="true" fill="none" height="14" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="14"><path d="m6 9 6 6 6-6"></path></svg>
            </summary>
            <div class="mobile-nav__group-content">
              {
                docsLinks.map((item) => (
                  <a class:list={["mobile-link", isActivePath(item.href) && "is-active"]} href={item.href}>
                    <span class="nav-link__dot"></span>
                    {item.label}
                  </a>
                ))
              }
            </div>
          </details>
          <details class="mobile-nav__group">
            <summary class="mobile-nav__label">
              Compare
              <svg aria-hidden="true" fill="none" height="14" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="14"><path d="m6 9 6 6 6-6"></path></svg>
            </summary>
            <div class="mobile-nav__group-content">
              {
                compareLinks.map((item) => (
                  <a class:list={["mobile-link", isActivePath(item.href) && "is-active"]} href={item.href}>
                    <span class="nav-link__dot"></span>
                    {item.label}
                  </a>
                ))
              }
            </div>
          </details>
          <details class="mobile-nav__group">
            <summary class="mobile-nav__label">
              Integrations
              <svg aria-hidden="true" fill="none" height="14" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="14"><path d="m6 9 6 6 6-6"></path></svg>
            </summary>
            <div class="mobile-nav__group-content">
              {
                integrationsLinks.map((item) => (
                  <a class:list={["mobile-link", item.href !== "/integrations/" && "mobile-link--subtle", isActivePath(item.href) && "is-active"]} href={item.href}>
                    <span class="nav-link__dot"></span>
                    {item.label}
                  </a>
                ))
              }
            </div>
          </details>
          <details class="mobile-nav__group">
            <summary class="mobile-nav__label">
              Community
              <svg aria-hidden="true" fill="none" height="14" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="14"><path d="m6 9 6 6 6-6"></path></svg>
            </summary>
            <div class="mobile-nav__group-content">
              {
                communityLinks.map((item) => (
                  <a class:list={["mobile-link", isActivePath(item.href) && "is-active"]} href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noreferrer" : undefined}>
                    <span class="nav-link__dot"></span>
                    {item.label}
                  </a>
                ))
              }
            </div>
          </details>
          <details class="mobile-nav__group">
            <summary class="mobile-nav__label">
              Contact
              <svg aria-hidden="true" fill="none" height="14" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="14"><path d="m6 9 6 6 6-6"></path></svg>
            </summary>
            <div class="mobile-nav__group-content">
              {
                contactLinks.map((item) => (
                  <a class:list={["mobile-link", isActivePath(item.href) && "is-active"]} href={item.href}>
                    <span class="nav-link__dot"></span>
                    {item.label}
                  </a>
                ))
              }
            </div>
          </details>
        </nav>
        <Button href={siteConfig.auth.login.href} variant="secondary" icon="arrow-right">
          Dashboard
        </Button>
      </div>
    </details>
    </div>
  </Container>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 50;
    padding-top: 0.45rem;
  }

  .site-header__frame {
    position: relative;
  }

  .site-header__frame::before {
    content: "";
    position: absolute;
    inset: -0.3rem 3rem auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(125, 211, 252, 0.55), transparent);
    opacity: 0.75;
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 0.7rem;
    min-height: var(--header-height);
    padding: 0.52rem 0.75rem;
    border: 1px solid rgba(125, 211, 252, 0.16);
    border-radius: 1rem;
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.08), rgba(255, 255, 255, 0.015)),
      linear-gradient(90deg, rgba(6, 9, 18, 0.94), rgba(11, 16, 30, 0.86) 50%, rgba(7, 10, 18, 0.94));
    box-shadow:
      0 18px 50px rgba(0, 0, 0, 0.32),
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      inset 0 0 0 1px rgba(125, 211, 252, 0.05);
    backdrop-filter: blur(20px);
  }

  .desktop-nav-shell {
    display: flex;
    align-items: center;
    justify-self: center;
  }

  .desktop-nav {
    display: inline-flex;
    justify-content: center;
    gap: 0.35rem;
    padding: 0.24rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.015)),
      rgba(5, 8, 16, 0.88);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .nav-link,
  .mobile-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--color-muted);
    font-size: 0.9rem;
    border-radius: 0.92rem;
    transition:
      color 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .nav-link {
    justify-content: center;
    min-height: 2.3rem;
    padding: 0.44rem 0.8rem;
  }

  .mobile-link {
    justify-content: flex-start;
    min-height: 2rem;
    padding: 0.35rem 0.6rem;
  }

  .nav-link__dot {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: rgba(125, 211, 252, 0.38);
    box-shadow: 0 0 14px rgba(125, 211, 252, 0.25);
  }

  .nav-link:hover,
  .mobile-link:hover,
  .nav-link.is-active,
  .mobile-link.is-active {
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.12), rgba(255, 255, 255, 0.03)),
      rgba(255, 255, 255, 0.03);
    color: var(--color-text);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 0 0 1px rgba(125, 211, 252, 0.14);
  }

  .nav-link.is-active .nav-link__dot,
  .mobile-link.is-active .nav-link__dot {
    background: var(--color-accent);
    box-shadow: 0 0 18px rgba(125, 211, 252, 0.7);
  }

  .mobile-nav {
    display: none;
  }

  .mobile-nav > summary {
    list-style: none;
    display: grid;
    gap: 0.3rem;
    width: 2.9rem;
    padding: 0.7rem;
    border: 1px solid rgba(125, 211, 252, 0.16);
    border-radius: 0.95rem;
    cursor: pointer;
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.08), rgba(255, 255, 255, 0.02)),
      rgba(255, 255, 255, 0.04);
  }

  .mobile-nav > summary::-webkit-details-marker {
    display: none;
  }

  .mobile-nav > summary span {
    height: 1.5px;
    border-radius: 999px;
    background: var(--color-text);
  }

  .mobile-nav__panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.8rem);
    width: min(18rem, 92vw);
    max-height: calc(100vh - var(--header-offset) - 0.75rem);
    overflow-y: auto;
    display: none;
    gap: 0.5rem;
    padding: 0.6rem;
    border: 1px solid rgba(125, 211, 252, 0.14);
    border-radius: 1.2rem;
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.06), rgba(255, 255, 255, 0.02)),
      rgba(7, 11, 20, 0.96);
    box-shadow: var(--shadow-card);
  }

  .mobile-nav[open] > .mobile-nav__panel {
    display: grid;
  }

  .mobile-nav__panel nav {
    display: grid;
    gap: 0.15rem;
  }

  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown summary {
    list-style: none;
    cursor: pointer;
  }

  .nav-dropdown summary::-webkit-details-marker {
    display: none;
  }

  .nav-dropdown__panel {
    position: absolute;
    top: calc(100% + 0.55rem);
    left: 0;
    display: none;
    min-width: 12rem;
    gap: 0.25rem;
    padding: 0.65rem;
    border: 1px solid rgba(125, 211, 252, 0.14);
    border-radius: 1rem;
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.06), rgba(255, 255, 255, 0.02)),
      rgba(7, 11, 20, 0.96);
    box-shadow: var(--shadow-card);
  }

  .nav-dropdown[open] > .nav-dropdown__panel {
    display: grid;
  }

  .nav-dropdown__panel--wide {
    min-width: 15rem;
  }

  .nav-dropdown__panel--scroll {
    max-height: min(70vh, 28rem);
    overflow-y: auto;
  }

  .nav-dropdown__panel a {
    color: var(--color-muted);
  }

  .nav-dropdown__panel a {
    display: inline-flex;
    align-items: center;
    min-height: 2.25rem;
    padding: 0.45rem 0.65rem;
    border-radius: 0.75rem;
  }

  .nav-dropdown__panel a:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-text);
  }

  .nav-dropdown__panel a.is-active {
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.12), rgba(255, 255, 255, 0.03)),
      rgba(255, 255, 255, 0.03);
    color: var(--color-text);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 0 0 1px rgba(125, 211, 252, 0.14);
  }

  .nav-dropdown.is-active > summary {
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.12), rgba(255, 255, 255, 0.03)),
      rgba(255, 255, 255, 0.03);
    color: var(--color-text);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 0 0 1px rgba(125, 211, 252, 0.14);
  }

  .mobile-nav__group {
    margin-top: 0.25rem;
  }
  
  .mobile-nav__group > summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 0.6rem;
    border-radius: 0.5rem;
  }

  .mobile-nav__group > summary::-webkit-details-marker {
    display: none;
  }

  .mobile-nav__group[open] > summary svg {
    transform: rotate(180deg);
  }

  .mobile-nav__group > summary svg {
    transition: transform 180ms ease;
  }

  .mobile-nav__group-content {
    display: none;
    gap: 0.15rem;
    padding-left: 0.5rem;
    margin-top: 0.25rem;
  }

  .mobile-nav__group[open] > .mobile-nav__group-content {
    display: grid;
  }

  .mobile-link--subtle {
    min-height: 1.8rem;
    padding-left: 0.85rem;
    font-size: 0.85rem;
  }

  .mobile-nav__label {
    font-size: 0.95rem;
    color: var(--color-text);
    font-weight: 500;
  }

  .desktop-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  @media (max-width: 900px) {
    .site-header__inner {
      grid-template-columns: auto 1fr auto;
    }

    .desktop-nav-shell,
    .desktop-cta {
      display: none;
    }

    .mobile-nav {
      display: block;
      justify-self: end;
      position: relative;
    }
  }
</style>

<script>
  const menuSelector = ".site-header details.mobile-nav, .site-header details.mobile-nav__group, .site-header details.nav-dropdown";
  const openMenuSelector = ".site-header details[open].mobile-nav, .site-header details[open].mobile-nav__group, .site-header details[open].nav-dropdown";

  const getManagedMenus = () => Array.from(document.querySelectorAll<HTMLDetailsElement>(menuSelector));
  const getOpenMenus = () => Array.from(document.querySelectorAll<HTMLDetailsElement>(openMenuSelector));

  const closeOpenMenus = (except: HTMLDetailsElement[] = []) => {
    const keep = new Set(except);
    getOpenMenus().forEach((details) => {
      if (!keep.has(details)) {
        details.removeAttribute("open");
      }
    });
  };

  const getMenuChain = (details: HTMLDetailsElement) => {
    const chain: HTMLDetailsElement[] = [details];
    let parent = details.parentElement?.closest("details");
    while (parent instanceof HTMLDetailsElement) {
      chain.push(parent);
      parent = parent.parentElement?.closest("details");
    }
    return chain;
  };

  const handleSummaryClick = (event: Event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const summary = target.closest("summary");
    if (!(summary instanceof HTMLElement)) return;

    const details = summary.parentElement;
    if (!(details instanceof HTMLDetailsElement) || !details.matches(menuSelector)) return;

    event.preventDefault();

    const willOpen = !details.hasAttribute("open");
    const chain = getMenuChain(details);
    closeOpenMenus(chain);

    if (willOpen) {
      chain.forEach((item) => item.setAttribute("open", ""));
    } else {
      details.removeAttribute("open");
    }
  };

  const handleDocumentClick = (event: Event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    if (target.closest(".site-header")) return;
    closeOpenMenus();
  };

  const handleHeaderLinkClick = (event: Event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;
    if (target.closest(".site-header a")) {
      closeOpenMenus();
    }
  };

  const handleEscape = (event: KeyboardEvent) => {
    if (event.key === "Escape") {
      closeOpenMenus();
    }
  };

  function initNav() {
    document.removeEventListener("click", handleSummaryClick, true);
    document.removeEventListener("click", handleDocumentClick, true);
    document.removeEventListener("click", handleHeaderLinkClick);
    document.removeEventListener("keydown", handleEscape);

    getManagedMenus().forEach((details) => {
      if (!details.querySelector("summary")) {
        details.removeAttribute("open");
      }
    });

    document.addEventListener("click", handleSummaryClick, true);
    document.addEventListener("click", handleDocumentClick, true);
    document.addEventListener("click", handleHeaderLinkClick);
    document.addEventListener("keydown", handleEscape);
  }

  document.addEventListener("astro:before-preparation", closeOpenMenus);
  document.addEventListener("astro:before-swap", closeOpenMenus);
  document.addEventListener("astro:page-load", initNav);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initNav);
  } else {
    initNav();
  }
</script>
