---
import BrandMark from "./BrandMark.astro";
import Button from "./Button.astro";
import Container from "./Container.astro";
import { siteConfig } from "../config/site";
import { docsContent } from "../content/docs";
import { comparePages } from "../content/compare-pages";
import { integrationsContent } from "../content/integrations";

const pathname = Astro.url.pathname;
const coreLinks = [
  { label: "Home", href: "/" },
  { label: "Pricing", href: "/pricing/" }
];
const docsLinks = [
  { label: "Docs Home", href: "/docs/" },
  ...docsContent.sections.map((section) => ({
    label: section.title,
    href: section.href
  }))
];
const compareLinks = [
  { label: "Compare Home", href: "/compare/" },
  { label: "Why Not Direct Pixels", href: "/why-not-direct-pixels/" },
  ...Object.entries(comparePages).map(([slug, page]) => ({
    label: slug === "cloudflare-zaraz" ? "Zaraz" : page.title.replace("EventsGateway vs ", ""),
    href: `/compare/${slug}/`
  }))
] as Array<{ label: string; href: string }>;
const integrationsLinks = [
  { label: "Integrations Home", href: "/integrations/" },
  ...integrationsContent.items.map((item) => ({
    label: item.label,
    href: `/integrations/${item.slug}/`
  }))
] as Array<{ label: string; href: string }>;
const integrationGroups = [
  {
    label: "Official Managed Components",
    items: integrationsContent.items
      .filter((item) => item.group === "Official Managed Components")
      .map((item) => ({
        label: item.label,
        href: `/integrations/${item.slug}/`
      }))
  },
  {
    label: "Community Managed Components",
    items: integrationsContent.items
      .filter((item) => item.group === "Community Managed Components")
      .map((item) => ({
        label: item.label,
        href: `/integrations/${item.slug}/`
      }))
  }
] as Array<{ label: string; items: Array<{ label: string; href: string }> }>;
const integrationsCountLabel = `Integrations (${integrationsContent.items.length})`;
const communityLinks = [
  { label: "Open Source", href: "/open-source/" },
  { label: "Install", href: "/install/" },
  { label: "Status", href: "/status/" },
  { label: "GitHub", href: siteConfig.social.github, external: true }
];
const contactLinks = [
  { label: "Contact", href: "/contact/" },
  { label: "Founder", href: "/founder/" }
];

function isActivePath(href: string) {
  if (href === "/") {
    return pathname === "/";
  }
  if (href === "/docs/") {
    return pathname.startsWith("/docs/");
  }
  if (href === "/compare/") {
    return pathname.startsWith("/compare/") || pathname === "/why-not-direct-pixels/";
  }
  return pathname === href || pathname.startsWith(href);
}

const docsActive = pathname.startsWith("/docs/");
const compareActive = pathname.startsWith("/compare/") || pathname === "/why-not-direct-pixels/";
const integrationsActive = pathname.startsWith("/integrations/");
const communityActive = pathname.startsWith("/open-source/") || pathname.startsWith("/install/") || pathname.startsWith("/status/");
const contactActive = pathname.startsWith("/contact/") || pathname.startsWith("/founder/");
---

<header class="site-header">
  <Container class="site-header__frame">
    <div class="site-header__inner">
      <BrandMark showTagline={false} />
      <div class="desktop-nav-shell">
        <nav class="desktop-nav" aria-label="Primary">
          {
            coreLinks.map((item) => (
              <a class:list={["nav-link", isActivePath(item.href) && "is-active"]} href={item.href}>
                <span class="nav-link__dot"></span>
                {item.label}
              </a>
            ))
          }
          <details class:list={["nav-dropdown", docsActive && "is-active"]}>
            <summary class="nav-link">
              <span class="nav-link__dot"></span>
              Docs
            </summary>
            <div class="nav-dropdown__panel nav-dropdown__panel--wide nav-dropdown__panel--scroll">
              {
                docsLinks.map((item) => (
                  <a class:list={[isActivePath(item.href) && "is-active"]} href={item.href}>
                    {item.label}
                  </a>
                ))
              }
            </div>
          </details>
          <details class:list={["nav-dropdown", compareActive && "is-active"]}>
            <summary class="nav-link">
              <span class="nav-link__dot"></span>
              Compare
            </summary>
            <div class="nav-dropdown__panel nav-dropdown__panel--wide nav-dropdown__panel--scroll">
              {
                compareLinks.map((item) => (
                  <a class:list={[isActivePath(item.href) && "is-active"]} href={item.href}>
                    {item.label}
                  </a>
                ))
              }
            </div>
          </details>
          <details class:list={["nav-dropdown", integrationsActive && "is-active"]}>
            <summary class="nav-link">
              <span class="nav-link__dot"></span>
              {integrationsCountLabel}
            </summary>
            <div class="nav-dropdown__panel nav-dropdown__panel--integrations nav-dropdown__panel--scroll">
              <a class:list={["nav-dropdown__home-link", isActivePath("/integrations/") && "is-active"]} href="/integrations/">
                Integrations Home
              </a>
              <div class="nav-dropdown__groups">
                {
                  integrationGroups.map((group) => (
                    <div class="nav-dropdown__group">
                      <span class="nav-dropdown__label">{group.label}</span>
                      {
                        group.items.map((item) => (
                          <a class:list={[isActivePath(item.href) && "is-active"]} href={item.href}>
                            {item.label}
                          </a>
                        ))
                      }
                    </div>
                  ))
                }
              </div>
            </div>
          </details>
          <details class:list={["nav-dropdown", communityActive && "is-active"]}>
            <summary class="nav-link">
              <span class="nav-link__dot"></span>
              Community
            </summary>
            <div class="nav-dropdown__panel">
              {
                communityLinks.map((item) => (
                  <a class:list={[isActivePath(item.href) && "is-active"]} href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noreferrer" : undefined}>
                    {item.label}
                  </a>
                ))
              }
            </div>
          </details>
          <details class:list={["nav-dropdown", contactActive && "is-active"]}>
            <summary class="nav-link">
              <span class="nav-link__dot"></span>
              Contact
            </summary>
            <div class="nav-dropdown__panel">
              {
                contactLinks.map((item) => (
                  <a href={item.href}>{item.label}</a>
                ))
              }
            </div>
          </details>
        </nav>
      </div>
      <div class="desktop-cta">
        <Button href={siteConfig.auth.login.href} variant="secondary" icon="arrow-right">
          Dashboard
        </Button>
      </div>
    <details class="mobile-nav">
      <summary aria-label="Open navigation menu">
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div class="mobile-nav__panel">
        <nav aria-label="Mobile">
          {
            coreLinks.map((item) => (
              <a class:list={["mobile-link", isActivePath(item.href) && "is-active"]} href={item.href}>
                <span class="nav-link__dot"></span>
                {item.label}
              </a>
            ))
          }
          <div class="mobile-nav__group">
            <span class="mobile-nav__label">Docs</span>
            {
              docsLinks.map((item) => (
                <a class:list={["mobile-link", isActivePath(item.href) && "is-active"]} href={item.href}>
                  <span class="nav-link__dot"></span>
                  {item.label}
                </a>
              ))
            }
          </div>
          <div class="mobile-nav__group">
            <span class="mobile-nav__label">Compare</span>
            {
              compareLinks.map((item) => (
                <a class:list={["mobile-link", isActivePath(item.href) && "is-active"]} href={item.href}>
                  <span class="nav-link__dot"></span>
                  {item.label}
                </a>
              ))
            }
          </div>
          <div class="mobile-nav__group">
            <span class="mobile-nav__label">Integrations</span>
            <a class:list={["mobile-link", isActivePath("/integrations/") && "is-active"]} href="/integrations/">
              <span class="nav-link__dot"></span>
              Integrations Home
            </a>
            {
              integrationGroups.map((group) => (
                <div class="mobile-nav__subgroup">
                  <span class="mobile-nav__subgroup-label">{group.label}</span>
                  {
                    group.items.map((item) => (
                      <a class:list={["mobile-link", "mobile-link--subtle", isActivePath(item.href) && "is-active"]} href={item.href}>
                        <span class="nav-link__dot"></span>
                        {item.label}
                      </a>
                    ))
                  }
                </div>
              ))
            }
          </div>
          <div class="mobile-nav__group">
            <span class="mobile-nav__label">Community</span>
            {
              communityLinks.map((item) => (
                <a class:list={["mobile-link", isActivePath(item.href) && "is-active"]} href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noreferrer" : undefined}>
                  <span class="nav-link__dot"></span>
                  {item.label}
                </a>
              ))
            }
          </div>
          <div class="mobile-nav__group">
            <span class="mobile-nav__label">Contact</span>
            {
              contactLinks.map((item) => (
                <a class:list={["mobile-link", isActivePath(item.href) && "is-active"]} href={item.href}>
                  <span class="nav-link__dot"></span>
                  {item.label}
                </a>
              ))
            }
          </div>
        </nav>
        <Button href={siteConfig.auth.login.href} variant="secondary" icon="arrow-right">
          Dashboard
        </Button>
      </div>
    </details>
    </div>
  </Container>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 50;
    padding-top: 0.45rem;
  }

  .site-header__frame {
    position: relative;
  }

  .site-header__frame::before {
    content: "";
    position: absolute;
    inset: -0.3rem 3rem auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(125, 211, 252, 0.55), transparent);
    opacity: 0.75;
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 0.7rem;
    min-height: var(--header-height);
    padding: 0.52rem 0.75rem;
    border: 1px solid rgba(125, 211, 252, 0.16);
    border-radius: 1rem;
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.08), rgba(255, 255, 255, 0.015)),
      linear-gradient(90deg, rgba(6, 9, 18, 0.94), rgba(11, 16, 30, 0.86) 50%, rgba(7, 10, 18, 0.94));
    box-shadow:
      0 18px 50px rgba(0, 0, 0, 0.32),
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      inset 0 0 0 1px rgba(125, 211, 252, 0.05);
    backdrop-filter: blur(20px);
  }

  .desktop-nav-shell {
    display: flex;
    align-items: center;
    justify-self: center;
  }

  .desktop-nav {
    display: inline-flex;
    justify-content: center;
    gap: 0.35rem;
    padding: 0.24rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.015)),
      rgba(5, 8, 16, 0.88);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .nav-link,
  .mobile-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 2.3rem;
    padding: 0.44rem 0.8rem;
    border-radius: 0.92rem;
    color: var(--color-muted);
    font-size: 0.9rem;
    transition:
      color 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .nav-link__dot {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: rgba(125, 211, 252, 0.38);
    box-shadow: 0 0 14px rgba(125, 211, 252, 0.25);
  }

  .nav-link:hover,
  .mobile-link:hover,
  .nav-link.is-active,
  .mobile-link.is-active {
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.12), rgba(255, 255, 255, 0.03)),
      rgba(255, 255, 255, 0.03);
    color: var(--color-text);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 0 0 1px rgba(125, 211, 252, 0.14);
  }

  .nav-link.is-active .nav-link__dot,
  .mobile-link.is-active .nav-link__dot {
    background: var(--color-accent);
    box-shadow: 0 0 18px rgba(125, 211, 252, 0.7);
  }

  .mobile-nav {
    display: none;
  }

  .mobile-nav summary {
    list-style: none;
    display: grid;
    gap: 0.3rem;
    width: 2.9rem;
    padding: 0.7rem;
    border: 1px solid rgba(125, 211, 252, 0.16);
    border-radius: 0.95rem;
    cursor: pointer;
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.08), rgba(255, 255, 255, 0.02)),
      rgba(255, 255, 255, 0.04);
  }

  .mobile-nav summary::-webkit-details-marker {
    display: none;
  }

  .mobile-nav summary span {
    height: 1.5px;
    border-radius: 999px;
    background: var(--color-text);
  }

  .mobile-nav__panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.8rem);
    width: min(18rem, 92vw);
    display: grid;
    gap: 0.85rem;
    padding: 0.9rem;
    border: 1px solid rgba(125, 211, 252, 0.14);
    border-radius: 1.2rem;
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.06), rgba(255, 255, 255, 0.02)),
      rgba(7, 11, 20, 0.96);
    box-shadow: var(--shadow-card);
  }

  .mobile-nav__panel nav {
    display: grid;
    gap: 0.35rem;
  }

  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown summary {
    list-style: none;
    cursor: pointer;
  }

  .nav-dropdown summary::-webkit-details-marker {
    display: none;
  }

  .nav-dropdown__panel {
    position: absolute;
    top: calc(100% + 0.55rem);
    left: 0;
    display: grid;
    min-width: 12rem;
    gap: 0.25rem;
    padding: 0.65rem;
    border: 1px solid rgba(125, 211, 252, 0.14);
    border-radius: 1rem;
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.06), rgba(255, 255, 255, 0.02)),
      rgba(7, 11, 20, 0.96);
    box-shadow: var(--shadow-card);
  }

  .nav-dropdown__panel--wide {
    min-width: 15rem;
  }

  .nav-dropdown__panel--integrations {
    min-width: 34rem;
    max-width: min(42rem, 92vw);
  }

  .nav-dropdown__panel--scroll {
    max-height: min(70vh, 28rem);
    overflow-y: auto;
  }

  .nav-dropdown__home-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.25rem;
    padding: 0.45rem 0.65rem;
    border-radius: 0.75rem;
    margin-bottom: 0.35rem;
  }

  .nav-dropdown__groups {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .nav-dropdown__group {
    display: grid;
    gap: 0.2rem;
    align-content: start;
  }

  .nav-dropdown__label,
  .mobile-nav__subgroup-label {
    color: var(--color-muted);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .nav-dropdown__panel a,
  .mobile-nav__label {
    color: var(--color-muted);
  }

  .nav-dropdown__panel a {
    display: inline-flex;
    align-items: center;
    min-height: 2.25rem;
    padding: 0.45rem 0.65rem;
    border-radius: 0.75rem;
  }

  .nav-dropdown__panel a:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-text);
  }

  .nav-dropdown__panel a.is-active {
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.12), rgba(255, 255, 255, 0.03)),
      rgba(255, 255, 255, 0.03);
    color: var(--color-text);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 0 0 1px rgba(125, 211, 252, 0.14);
  }

  .nav-dropdown.is-active > summary {
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.12), rgba(255, 255, 255, 0.03)),
      rgba(255, 255, 255, 0.03);
    color: var(--color-text);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 0 0 1px rgba(125, 211, 252, 0.14);
  }

  .mobile-nav__group {
    display: grid;
    gap: 0.35rem;
    margin-top: 0.5rem;
  }

  .mobile-nav__subgroup {
    display: grid;
    gap: 0.3rem;
    margin-top: 0.45rem;
  }

  .mobile-link--subtle {
    min-height: 2.1rem;
    padding-left: 0.95rem;
    font-size: 0.88rem;
  }

  .mobile-nav__label {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .desktop-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  @media (max-width: 900px) {
    .site-header__inner {
      grid-template-columns: auto 1fr auto;
    }

    .desktop-nav-shell,
    .desktop-cta {
      display: none;
    }

    .mobile-nav {
      display: block;
      justify-self: end;
      position: relative;
    }
  }
</style>

<script>
  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const openDetails = document.querySelectorAll<HTMLDetailsElement>("details[open].mobile-nav, details[open].desktop-dropdown");
    
    openDetails.forEach((details) => {
      if (!details.contains(target)) {
        details.removeAttribute("open");
      }
    });
  });
</script>
