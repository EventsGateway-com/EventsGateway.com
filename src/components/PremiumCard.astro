---
import Icon from "./Icon.astro";

type IconName =
  | "spark"
  | "terminal"
  | "cloud"
  | "shield"
  | "download"
  | "mail"
  | "arrow-right"
  | "check"
  | "bolt"
  | "layers";

const {
  icon,
  imageSrc,
  imageAlt,
  title,
  text,
  eyebrow,
  href,
  step,
  class: className = "",
  disabled = false
} = Astro.props as {
  icon?: IconName;
  imageSrc?: string;
  imageAlt?: string;
  title?: string;
  text?: string;
  eyebrow?: string;
  href?: string;
  step?: string;
  class?: string;
  disabled?: boolean;
};

const Tag = href && !disabled ? "a" : "div";
---

<Tag
  class:list={["premium-card", disabled && "premium-card--disabled", className]}
  href={Tag === "a" ? href : undefined}
  data-step={step}
>
  <div class="premium-card__inner">
    <div class="premium-card__header">
      {imageSrc ? (
        <span class="premium-card__logo">
          <img src={imageSrc} alt={imageAlt ?? title ?? "Integration logo"} loading="lazy" />
        </span>
      ) : icon && (
        <span class="premium-card__icon">
          <Icon name={icon} size={20} />
        </span>
      )}
      {eyebrow && <span class="premium-card__eyebrow">{eyebrow}</span>}
    </div>
    {title && <h3 class="premium-card__title">{title}</h3>}
    {text && <p class="premium-card__text">{text}</p>}
    <slot />
  </div>
</Tag>

<style>
  .premium-card {
    position: relative;
    display: block;
    height: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.025)),
      rgba(8, 12, 22, 0.86);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition:
      transform 220ms ease,
      border-color 220ms ease,
      box-shadow 220ms ease,
      background-color 220ms ease;
  }

  .premium-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(140deg, rgba(125, 211, 252, 0.12), transparent 36%, rgba(167, 139, 250, 0.08));
    opacity: 0.9;
    pointer-events: none;
  }

  .premium-card:hover {
    transform: translateY(-4px);
    border-color: rgba(125, 211, 252, 0.35);
    box-shadow:
      var(--shadow-card),
      0 0 0 1px rgba(125, 211, 252, 0.1);
  }

  .premium-card--disabled {
    opacity: 0.72;
  }

  .premium-card--disabled:hover {
    transform: none;
    border-color: var(--color-border);
  }

  .premium-card__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    height: 100%;
    padding: 1.45rem;
  }

  .premium-card__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .premium-card__icon {
    width: 2.85rem;
    height: 2.85rem;
    display: grid;
    place-items: center;
    border-radius: 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.055);
    color: var(--color-accent);
  }

  .premium-card__logo {
    width: 3rem;
    height: 3rem;
    display: grid;
    place-items: center;
  }

  .premium-card__logo img {
    width: 3rem;
    height: 3rem;
    display: block;
    border-radius: 0.9rem;
  }

  .premium-card__eyebrow {
    color: var(--color-subtle);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .premium-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: -0.02em;
  }

  .premium-card__text {
    margin: 0;
    color: var(--color-muted);
    line-height: 1.65;
  }
</style>
