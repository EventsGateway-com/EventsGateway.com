---
import Icon from "./Icon.astro";

const { instanceId = "primary" } = Astro.props;

const windows = [
  { id: "terminal", title: "Terminal", icon: "terminal", x: 6, y: 7, w: 40, h: 31 },
  { id: "planner", title: "Reasoning Stack", icon: "spark", x: 49, y: 9, w: 34, h: 28 },
  { id: "monitor", title: "Deploy Monitor", icon: "cloud", x: 18, y: 42, w: 31, h: 27 },
  { id: "mesh", title: "Execution Mesh", icon: "layers", x: 54, y: 41, w: 29, h: 24 }
] as const;
---

<div class="mockup surface-panel" data-window-matrix data-instance={instanceId}>
  <div class="surface-panel__inner">
    <div class="mockup__topbar">
      <div class="mockup__lights">
        <span></span>
        <span></span>
        <span></span>
      </div>
      <div class="mockup__path">execution.command-lattice.dev</div>
      <div class="mockup__status">Ops graph online</div>
    </div>

    <div class="mockup__telemetry">
      <div class="telemetry-chip"><span class="telemetry-chip__label">Compute lane</span><strong>Scoped</strong></div>
      <div class="telemetry-chip"><span class="telemetry-chip__label">Review state</span><strong>Visible</strong></div>
      <div class="telemetry-chip"><span class="telemetry-chip__label">Deploy posture</span><strong>Edge static</strong></div>
      <div class="telemetry-chip"><span class="telemetry-chip__label">Signal quality</span><strong>Low noise</strong></div>
    </div>

    <div class="mockup__stage">
      <div class="mockup__grid"></div>

      {
        windows.map((window, index) => (
          <article
            class="widget-window"
            data-window-id={window.id}
            data-x={window.x}
            data-y={window.y}
            data-w={window.w}
            data-h={window.h}
            data-z={index + 1}
          >
            <header class="widget-window__bar" data-drag-handle>
              <div class="widget-window__title">
                <Icon name={window.icon} size={15} />
                <span>{window.title}</span>
              </div>
              <div class="widget-window__actions">
                <button class="widget-window__action" type="button" data-action="minimize" aria-label={`Minimize ${window.title}`}>
                  <span class="widget-window__glyph widget-window__glyph--minimize"></span>
                </button>
                <button class="widget-window__action" type="button" data-action="toggle-maximize" aria-label={`Zoom ${window.title}`}>
                  <span class="widget-window__glyph widget-window__glyph--maximize"></span>
                </button>
              </div>
            </header>

            <div class="widget-window__body">
              {
                window.id === "terminal" && (
                  <div class="widget-terminal">
                    <code>
                      <span>$ define target --scope public-site</span>
                      <span>$ allocate reasoning rails --mode scoped</span>
                      <span>$ run delivery pass --stack build,review</span>
                      <span class="widget-terminal__success">ready for controlled deploy</span>
                    </code>
                  </div>
                )
              }
              {
                window.id === "planner" && (
                  <div class="widget-list">
                    <div class="widget-list__row"><strong>Design system</strong><span>Shared surfaces and command states</span></div>
                    <div class="widget-list__row"><strong>Implementation rail</strong><span>Scoped execution with visible checkpoints</span></div>
                    <div class="widget-list__row"><strong>Verification pass</strong><span>Diagnostics and deploy audit before release</span></div>
                  </div>
                )
              }
              {
                window.id === "monitor" && (
                  <div class="widget-metrics">
                    <div class="widget-metrics__item"><span>Edge cache</span><strong>92%</strong></div>
                    <div class="widget-metrics__item"><span>Latency</span><strong>34ms</strong></div>
                    <div class="widget-metrics__item"><span>Build sync</span><strong>Green</strong></div>
                    <div class="widget-bar"><span style="width: 88%"></span></div>
                    <div class="widget-bar"><span style="width: 74%"></span></div>
                  </div>
                )
              }
              {
                window.id === "mesh" && (
                  <div class="widget-mesh">
                    <span class="mesh-node mesh-node--active"></span>
                    <span class="mesh-node"></span>
                    <span class="mesh-node mesh-node--accent"></span>
                    <span class="mesh-node"></span>
                    <span class="mesh-node"></span>
                    <span class="mesh-node mesh-node--active"></span>
                    <span class="mesh-node"></span>
                    <span class="mesh-node mesh-node--accent"></span>
                    <span class="mesh-node"></span>
                  </div>
                )
              }
            </div>
          </article>
        ))
      }

      <div class="mockup__dock" aria-label="Minimized windows">
        {
          windows.map((window) => (
            <button class="mockup__dock-item" type="button" data-dock-item={window.id}>
              <Icon name={window.icon} size={14} />
              <span>{window.title}</span>
            </button>
          ))
        }
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const initializeWindowMatrix = (root) => {
      if (!root || root.dataset.ready === "true") return;
      root.dataset.ready = "true";

      const stage = root.querySelector(".mockup__stage");
      const windows = Array.from(root.querySelectorAll(".widget-window"));
      const dockItems = new Map(
        Array.from(root.querySelectorAll("[data-dock-item]")).map((item) => [item.dataset.dockItem, item])
      );
      const storageKey = `window-matrix:${root.dataset.instance || "default"}`;
      let zIndex = windows.length + 1;

      const defaults = Object.fromEntries(
        windows.map((window) => [
          window.dataset.windowId,
          {
            x: Number(window.dataset.x),
            y: Number(window.dataset.y),
            w: Number(window.dataset.w),
            h: Number(window.dataset.h),
            z: Number(window.dataset.z),
            minimized: false,
            maximized: false,
            restoreRect: null
          }
        ])
      );

      let state = structuredClone(defaults);

      try {
        const saved = localStorage.getItem(storageKey);
        if (saved) {
          state = { ...state, ...JSON.parse(saved) };
        }
      } catch {}

      const saveState = () => {
        try {
          localStorage.setItem(storageKey, JSON.stringify(state));
        } catch {}
      };

      const clampRect = (rect) => ({
        ...rect,
        w: Math.min(Math.max(rect.w, 24), 94),
        h: Math.min(Math.max(rect.h, 20), 76),
        x: Math.min(Math.max(rect.x, 2), 98 - Math.min(Math.max(rect.w, 24), 94)),
        y: Math.min(Math.max(rect.y, 3), 84 - Math.min(Math.max(rect.h, 20), 76))
      });

      const applyWindow = (window) => {
        const id = window.dataset.windowId;
        const current = clampRect(state[id]);
        state[id] = current;
        window.style.left = `${current.x}%`;
        window.style.top = `${current.y}%`;
        window.style.width = `${current.w}%`;
        window.style.height = `${current.h}%`;
        window.style.zIndex = String(current.z);
        window.classList.toggle("is-minimized", current.minimized);
        window.classList.toggle("is-maximized", current.maximized);
        dockItems.get(id)?.classList.toggle("is-visible", current.minimized);
      };

      const render = () => {
        windows.forEach(applyWindow);
        saveState();
      };

      const bringToFront = (id) => {
        state[id].z = zIndex++;
      };

      const minimizeWindow = (id) => {
        state[id].minimized = true;
        state[id].maximized = false;
        render();
      };

      const toggleMaximize = (id) => {
        const current = state[id];
        if (current.maximized && current.restoreRect) {
          Object.assign(current, current.restoreRect, { maximized: false, restoreRect: null, minimized: false });
        } else {
          current.restoreRect = { x: current.x, y: current.y, w: current.w, h: current.h };
          Object.assign(current, { x: 3, y: 6, w: 94, h: 72, maximized: true, minimized: false });
        }
        bringToFront(id);
        render();
      };

      const restoreWindow = (id) => {
        state[id].minimized = false;
        bringToFront(id);
        render();
      };

      windows.forEach((window) => {
        const id = window.dataset.windowId;
        const handle = window.querySelector("[data-drag-handle]");
        handle?.addEventListener("pointerdown", (event) => {
          if (event.target.closest("button")) return;
          if (state[id].maximized) return;
          bringToFront(id);
          render();
          const stageRect = stage.getBoundingClientRect();
          const start = { x: event.clientX, y: event.clientY, rect: { ...state[id] } };

          const onMove = (moveEvent) => {
            const nextRect = {
              ...state[id],
              x: start.rect.x + ((moveEvent.clientX - start.x) / stageRect.width) * 100,
              y: start.rect.y + ((moveEvent.clientY - start.y) / stageRect.height) * 100
            };
            state[id] = clampRect(nextRect);
            applyWindow(window);
          };

          const onUp = () => {
            window.removeEventListener("pointermove", onMove);
            window.removeEventListener("pointerup", onUp);
            window.releasePointerCapture(event.pointerId);
            saveState();
          };

          window.setPointerCapture(event.pointerId);
          window.addEventListener("pointermove", onMove);
          window.addEventListener("pointerup", onUp, { once: true });
        });

        window.querySelector('[data-action="minimize"]')?.addEventListener("click", () => minimizeWindow(id));
        window.querySelector('[data-action="toggle-maximize"]')?.addEventListener("click", () => toggleMaximize(id));
        window.addEventListener("pointerdown", () => {
          if (!state[id].minimized) {
            bringToFront(id);
            render();
          }
        });
      });

      dockItems.forEach((item, id) => item.addEventListener("click", () => restoreWindow(id)));
      render();
    };

    document.querySelectorAll("[data-window-matrix]").forEach(initializeWindowMatrix);
  })();
</script>

<style>
  .mockup { padding: 1rem; }
  .mockup__topbar { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 1rem; padding: 0.9rem 1rem 1rem; border-bottom: 1px solid rgba(255,255,255,.08); color: var(--color-muted); font-size: .9rem; }
  .mockup__lights { display: inline-flex; gap: .35rem; }
  .mockup__lights span { width: .62rem; height: .62rem; border-radius: 999px; background: rgba(255,255,255,.24); }
  .mockup__lights span:first-child { background: rgba(251,113,133,.7); }
  .mockup__lights span:nth-child(2) { background: rgba(248,215,141,.7); }
  .mockup__lights span:nth-child(3) { background: rgba(52,211,153,.7); }
  .mockup__path { justify-self: center; font-family: var(--font-mono); font-size: .82rem; }
  .mockup__status { padding: .35rem .6rem; border-radius: 999px; border: 1px solid rgba(255,255,255,.12); background: rgba(255,255,255,.04); font-size: .75rem; }
  .mockup__telemetry { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: .8rem; padding: .9rem 1rem 0; }
  .telemetry-chip { display: grid; gap: .35rem; padding: .85rem .9rem; border: 1px solid rgba(125,211,252,.1); border-radius: .95rem; background: linear-gradient(180deg, rgba(125,211,252,.08), rgba(255,255,255,.02)), rgba(255,255,255,.025); }
  .telemetry-chip__label { color: var(--color-subtle); font-size: .7rem; letter-spacing: .14em; text-transform: uppercase; }
  .telemetry-chip strong { font-size: .94rem; letter-spacing: -.02em; }
  .mockup__stage { position: relative; min-height: 40rem; margin: 1rem; border: 1px solid rgba(125,211,252,.1); border-radius: 1.25rem; background: radial-gradient(circle at top, rgba(125,211,252,.08), transparent 38%), rgba(4,8,17,.92); overflow: hidden; }
  .mockup__grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(125,211,252,.05) 1px, transparent 1px), linear-gradient(90deg, rgba(125,211,252,.05) 1px, transparent 1px); background-size: 32px 32px; opacity: .35; pointer-events: none; }
  .widget-window { position: absolute; display: grid; grid-template-rows: auto 1fr; border: 1px solid rgba(125,211,252,.14); border-radius: 1rem; background: linear-gradient(180deg, rgba(125,211,252,.08), rgba(255,255,255,.02)), rgba(8,12,23,.92); box-shadow: 0 24px 60px rgba(0,0,0,.32); overflow: hidden; transition: box-shadow .2s ease, border-color .2s ease, transform .2s ease, opacity .2s ease; }
  .widget-window:hover { border-color: rgba(125,211,252,.22); box-shadow: 0 28px 70px rgba(0,0,0,.42); }
  .widget-window.is-minimized { opacity: 0; pointer-events: none; transform: scale(.95); }
  .widget-window__bar { display: flex; align-items: center; justify-content: space-between; gap: .75rem; min-height: 2.9rem; padding: .7rem .8rem; border-bottom: 1px solid rgba(255,255,255,.08); cursor: grab; background: rgba(5,9,18,.68); }
  .widget-window__title { display: inline-flex; align-items: center; gap: .6rem; min-width: 0; color: var(--color-text); font-size: .85rem; letter-spacing: .02em; }
  .widget-window__title span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .widget-window__actions { display: inline-flex; gap: .4rem; }
  .widget-window__action { width: 1.75rem; height: 1.75rem; display: grid; place-items: center; border: 1px solid rgba(255,255,255,.08); border-radius: .5rem; background: rgba(255,255,255,.03); color: var(--color-muted); cursor: pointer; transition: background-color .18s ease, border-color .18s ease; }
  .widget-window__action:hover { background: rgba(125,211,252,.08); border-color: rgba(125,211,252,.2); }
  .widget-window__glyph { position: relative; display: block; width: .85rem; height: .85rem; }
  .widget-window__glyph--minimize::before { content: ""; position: absolute; left: .08rem; right: .08rem; bottom: .18rem; height: 1.5px; border-radius: 999px; background: currentColor; }
  .widget-window__glyph--maximize::before { content: ""; position: absolute; inset: .08rem; border: 1.5px solid currentColor; border-radius: .1rem; }
  .widget-window__body { padding: 1rem; overflow: hidden; }
  .widget-terminal code { display: grid; gap: .75rem; color: var(--color-muted); font-family: var(--font-mono); font-size: .82rem; }
  .widget-terminal__success { color: var(--color-success); }
  .widget-list { display: grid; gap: .9rem; }
  .widget-list__row { display: grid; gap: .22rem; }
  .widget-list__row strong { font-size: .95rem; }
  .widget-list__row span { color: var(--color-muted); line-height: 1.55; }
  .widget-metrics { display: grid; gap: .8rem; }
  .widget-metrics__item { display: flex; align-items: center; justify-content: space-between; gap: .75rem; color: var(--color-muted); }
  .widget-metrics__item strong { color: var(--color-text); font-size: 1rem; }
  .widget-bar { height: .55rem; border-radius: 999px; background: rgba(255,255,255,.06); overflow: hidden; }
  .widget-bar span { display: block; height: 100%; border-radius: inherit; background: linear-gradient(90deg, var(--color-accent), var(--color-accent-2)); box-shadow: 0 0 18px rgba(125,211,252,.25); }
  .widget-mesh { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .65rem; }
  .mesh-node { aspect-ratio: 1; border-radius: .8rem; border: 1px solid rgba(255,255,255,.08); background: rgba(255,255,255,.03); }
  .mesh-node--active { background: radial-gradient(circle at 50% 50%, rgba(125,211,252,.4), rgba(125,211,252,.08) 65%, rgba(255,255,255,.02)); border-color: rgba(125,211,252,.22); box-shadow: inset 0 0 22px rgba(125,211,252,.12); }
  .mesh-node--accent { background: radial-gradient(circle at 50% 50%, rgba(167,139,250,.35), rgba(167,139,250,.08) 65%, rgba(255,255,255,.02)); border-color: rgba(167,139,250,.22); }
  .mockup__dock { position: absolute; left: 1rem; right: 1rem; bottom: 1rem; display: flex; gap: .7rem; padding: .8rem; border: 1px solid rgba(125,211,252,.1); border-radius: 1rem; background: linear-gradient(180deg, rgba(125,211,252,.06), rgba(255,255,255,.02)), rgba(6,10,18,.92); backdrop-filter: blur(12px); }
  .mockup__dock-item { display: none; align-items: center; gap: .55rem; min-height: 2.7rem; padding: .55rem .8rem; border: 1px solid rgba(255,255,255,.08); border-radius: .85rem; background: rgba(255,255,255,.03); color: var(--color-muted); cursor: pointer; }
  .mockup__dock-item.is-visible { display: inline-flex; }
  .mockup__dock-item:hover { color: var(--color-text); border-color: rgba(125,211,252,.18); }
  @media (max-width: 960px) { .mockup__telemetry { grid-template-columns: repeat(2, minmax(0, 1fr)); } .mockup__stage { min-height: 48rem; } }
  @media (max-width: 720px) { .mockup__topbar,.mockup__telemetry { grid-template-columns: 1fr; } .mockup__path { justify-self: start; } .mockup__stage { min-height: 54rem; margin: .8rem; } .mockup__dock { flex-wrap: wrap; } }
</style>
