---
const { class: className = "" } = Astro.props as { class?: string };
---

<div class:list={["surface-glow", className]} aria-hidden="true"></div>

<style>
  .surface-glow {
    position: absolute;
    inset: auto;
    width: min(28rem, 50vw);
    aspect-ratio: 1;
    border-radius: 999px;
    background:
      radial-gradient(circle, rgba(125, 211, 252, 0.28), rgba(125, 211, 252, 0.06) 42%, transparent 72%);
    filter: blur(24px);
    pointer-events: none;
    z-index: -1;
  }
</style>
