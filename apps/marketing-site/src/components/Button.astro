---
import Icon from "./Icon.astro";

type Variant = "primary" | "secondary" | "ghost";
type IconName = "download" | "mail" | "arrow-right" | "spark" | "terminal";

const {
  href,
  variant = "primary",
  class: className = "",
  icon,
  iconSide = "right",
  disabled = false,
  type = "button"
} = Astro.props as {
  href?: string;
  variant?: Variant;
  class?: string;
  icon?: IconName;
  iconSide?: "left" | "right";
  disabled?: boolean;
  type?: "button" | "submit" | "reset";
};

const classes = ["button", `button--${variant}`, disabled && "is-disabled", className];
---

{
  href ? (
    <a
      class:list={classes}
      href={disabled ? undefined : href}
      aria-disabled={disabled ? "true" : undefined}
      tabindex={disabled ? "-1" : undefined}
    >
      {icon && iconSide === "left" && <Icon name={icon} size={18} class="button__icon" />}
      <slot />
      {icon && iconSide === "right" && <Icon name={icon} size={18} class="button__icon" />}
    </a>
  ) : (
    <button class:list={classes} type={type} disabled={disabled}>
      {icon && iconSide === "left" && <Icon name={icon} size={18} class="button__icon" />}
      <slot />
      {icon && iconSide === "right" && <Icon name={icon} size={18} class="button__icon" />}
    </button>
  )
}

<style>
  .button {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    min-height: 3.25rem;
    padding: 0.9rem 1.2rem;
    border-radius: 999px;
    border: 1px solid transparent;
    font-weight: 600;
    letter-spacing: -0.01em;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease,
      color 180ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button--primary {
    background:
      linear-gradient(135deg, rgba(125, 211, 252, 0.92), rgba(167, 139, 250, 0.92)),
      rgba(255, 255, 255, 0.08);
    color: #02050a;
    box-shadow: 0 14px 40px rgba(125, 211, 252, 0.22);
  }

  .button--primary:hover {
    box-shadow: 0 18px 48px rgba(125, 211, 252, 0.28);
  }

  .button--secondary {
    border-color: var(--color-border);
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text);
  }

  .button--secondary:hover {
    border-color: rgba(125, 211, 252, 0.4);
    background: rgba(255, 255, 255, 0.07);
  }

  .button--ghost {
    min-height: 2.75rem;
    padding-inline: 0;
    border-radius: 0;
    background: transparent;
    color: var(--color-accent);
  }

  .button--ghost:hover {
    transform: translateX(2px);
    color: var(--color-text);
  }

  .button__icon {
    flex: 0 0 auto;
  }

  .is-disabled,
  .button:disabled {
    cursor: not-allowed;
    opacity: 0.56;
    transform: none;
    box-shadow: none;
    pointer-events: none;
  }
</style>
