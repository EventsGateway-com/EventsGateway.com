---
import BrandMark from "./BrandMark.astro";
import Button from "./Button.astro";
import Container from "./Container.astro";
import { primaryNav } from "../config/nav";
import { siteConfig } from "../config/site";

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <Container class="site-header__frame">
    <div class="site-header__inner">
      <BrandMark />
      <div class="desktop-nav-shell">
        <span class="desktop-nav-shell__label">Navigation</span>
        <nav class="desktop-nav" aria-label="Primary">
          {
            primaryNav.map((item) => (
              <a class:list={["nav-link", pathname === item.href && "is-active"]} href={item.href}>
                <span class="nav-link__dot"></span>
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
      <div class="desktop-cta">
        <span class="header-status">Free-tier friendly</span>
        <Button href={siteConfig.cta.primary.href} variant="secondary" icon="download">
          {siteConfig.cta.primary.label}
        </Button>
      </div>
    <details class="mobile-nav">
      <summary aria-label="Open navigation menu">
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div class="mobile-nav__panel">
        <nav aria-label="Mobile">
          {
            primaryNav.map((item) => (
              <a class:list={["mobile-link", pathname === item.href && "is-active"]} href={item.href}>
                <span class="nav-link__dot"></span>
                {item.label}
              </a>
            ))
          }
        </nav>
        <Button href={siteConfig.cta.secondary.href} variant="primary" icon="mail">
          {siteConfig.cta.secondary.label}
        </Button>
      </div>
    </details>
    </div>
  </Container>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 50;
    padding-top: 1rem;
  }

  .site-header__frame {
    position: relative;
  }

  .site-header__frame::before {
    content: "";
    position: absolute;
    inset: -0.45rem 3rem auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(125, 211, 252, 0.55), transparent);
    opacity: 0.75;
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 1rem;
    min-height: var(--header-height);
    padding: 0.9rem 1.1rem;
    border: 1px solid rgba(125, 211, 252, 0.14);
    border-radius: 1.35rem;
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.08), rgba(255, 255, 255, 0.015)),
      linear-gradient(90deg, rgba(6, 9, 18, 0.94), rgba(11, 16, 30, 0.86) 50%, rgba(7, 10, 18, 0.94));
    box-shadow:
      0 18px 50px rgba(0, 0, 0, 0.32),
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      inset 0 0 0 1px rgba(125, 211, 252, 0.05);
    backdrop-filter: blur(20px);
  }

  .desktop-nav-shell {
    display: grid;
    gap: 0.45rem;
    justify-self: center;
  }

  .desktop-nav-shell__label {
    padding-left: 0.8rem;
    color: var(--color-subtle);
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .desktop-nav {
    display: inline-flex;
    justify-content: center;
    gap: 0.35rem;
    padding: 0.35rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.015)),
      rgba(5, 8, 16, 0.88);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .nav-link,
  .mobile-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 2.75rem;
    padding: 0.6rem 1rem;
    border-radius: 999px;
    color: var(--color-muted);
    transition:
      color 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .nav-link__dot {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: rgba(125, 211, 252, 0.38);
    box-shadow: 0 0 14px rgba(125, 211, 252, 0.25);
  }

  .nav-link:hover,
  .mobile-link:hover,
  .nav-link.is-active,
  .mobile-link.is-active {
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.12), rgba(255, 255, 255, 0.03)),
      rgba(255, 255, 255, 0.03);
    color: var(--color-text);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 0 0 1px rgba(125, 211, 252, 0.14);
  }

  .nav-link.is-active .nav-link__dot,
  .mobile-link.is-active .nav-link__dot {
    background: var(--color-accent);
    box-shadow: 0 0 18px rgba(125, 211, 252, 0.7);
  }

  .mobile-nav {
    display: none;
  }

  .mobile-nav summary {
    list-style: none;
    display: grid;
    gap: 0.3rem;
    width: 2.9rem;
    padding: 0.7rem;
    border: 1px solid rgba(125, 211, 252, 0.16);
    border-radius: 0.95rem;
    cursor: pointer;
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.08), rgba(255, 255, 255, 0.02)),
      rgba(255, 255, 255, 0.04);
  }

  .mobile-nav summary::-webkit-details-marker {
    display: none;
  }

  .mobile-nav summary span {
    height: 1.5px;
    border-radius: 999px;
    background: var(--color-text);
  }

  .mobile-nav__panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.8rem);
    width: min(18rem, 92vw);
    display: grid;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid rgba(125, 211, 252, 0.14);
    border-radius: 1.2rem;
    background:
      linear-gradient(180deg, rgba(125, 211, 252, 0.06), rgba(255, 255, 255, 0.02)),
      rgba(7, 11, 20, 0.96);
    box-shadow: var(--shadow-card);
  }

  .mobile-nav__panel nav {
    display: grid;
    gap: 0.35rem;
  }

  .desktop-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .header-status {
    display: inline-flex;
    align-items: center;
    min-height: 2.5rem;
    padding: 0.45rem 0.8rem;
    border: 1px solid rgba(52, 211, 153, 0.14);
    border-radius: 999px;
    background: rgba(52, 211, 153, 0.07);
    color: #a5f3c6;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .site-header__inner {
      grid-template-columns: auto 1fr auto;
    }

    .desktop-nav-shell,
    .desktop-cta {
      display: none;
    }

    .mobile-nav {
      display: block;
      justify-self: end;
      position: relative;
    }
  }
</style>
