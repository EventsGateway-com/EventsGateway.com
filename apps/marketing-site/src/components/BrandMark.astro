---
import Icon from "./Icon.astro";
import { siteConfig } from "../config/site";
---

<a class="brand" href="/" aria-label={`${siteConfig.name} home`}>
  <span class="brand__glyph">
    <Icon name="spark" size={18} />
  </span>
  <span class="brand__text">
    <strong>{siteConfig.name}</strong>
    <small>{siteConfig.tagline}</small>
  </span>
</a>

<style>
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    min-width: 0;
  }

  .brand__glyph {
    width: 2.8rem;
    height: 2.8rem;
    display: grid;
    place-items: center;
    border-radius: 0.95rem;
    border: 1px solid rgba(125, 211, 252, 0.28);
    background:
      linear-gradient(140deg, rgba(125, 211, 252, 0.28), rgba(167, 139, 250, 0.22)),
      rgba(255, 255, 255, 0.05);
    color: var(--color-text);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .brand__text {
    display: grid;
    gap: 0.2rem;
    min-width: 0;
  }

  .brand strong {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 650;
    letter-spacing: -0.02em;
  }

  .brand small {
    display: block;
    max-width: 24ch;
    color: var(--color-subtle);
    font-size: 0.74rem;
    line-height: 1.4;
  }

  @media (max-width: 720px) {
    .brand small {
      display: none;
    }
  }
</style>
