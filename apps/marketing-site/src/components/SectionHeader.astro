---
const {
  eyebrow,
  title,
  description,
  align = "left",
  class: className = ""
} = Astro.props as {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  class?: string;
};
---

<div class:list={["content-lead", align === "center" && "content-lead--center", className]}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2 class="section-title">{title}</h2>
  {description && <p class="section-copy">{description}</p>}
</div>

<style>
  .content-lead--center {
    justify-items: center;
    text-align: center;
  }

  .content-lead--center .section-title,
  .content-lead--center .section-copy {
    max-width: 20ch;
  }
  .content-lead--center .section-copy {
    max-width: 38rem;
  }
</style>
